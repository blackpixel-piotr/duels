@using Duels.Application.GameSession
@using Duels.Domain.ValueObjects
@using Duels.Domain.Entities

<div class="quickslot-bar">
    @{
        var weaponSlots     = WeaponSlots().ToList();
        var protectActive   = State?.Player?.ActiveProtection == ProtectionPrayer.Melee;
        var pietyActive     = State?.Player?.PietyActive == true;
        var noPrayer        = (State?.Player?.PrayerPoints ?? 0) <= 0;
    }
    @if (State?.InDuel == true)
    {
        @if (weaponSlots.Count == 0)
        {
            <button class="quickslot" title="attack" disabled="@Disabled" @onclick='() => Fire("attack")'>
                <span class="qs-icon">⚔</span>
                <span class="qs-label">ATTACK</span>
            </button>
        }
        else
        {
            @foreach (var slot in weaponSlots)
            {
                var isEquipped  = State?.Player?.GetEquippedWeaponId() == slot.WeaponId;
                var depleted    = SpecDepleted(slot.WeaponId);
                var slotLocal   = slot;
                <button class="quickslot @(isEquipped ? "qs-equipped" : "") @(depleted ? "qs-spec-depleted" : "")"
                        title="@slot.Command"
                        disabled="@Disabled"
                        @onclick="() => Fire(slotLocal.Command)">
                    @if (_specCosts.TryGetValue(slot.WeaponId, out int cost))
                    {
                        <span class="qs-spec-badge">@cost%</span>
                    }
                    <span class="qs-icon">⚔</span>
                    <span class="qs-label">@slot.Label</span>
                </button>
            }
        }

        <button class="quickslot @(protectActive ? "qs-equipped" : "") @(noPrayer ? "qs-spec-depleted" : "")"
                title="protect_melee"
                disabled="@Disabled"
                @onclick='() => Fire("protect_melee")'>
            <span class="qs-icon">⛉</span>
            <span class="qs-label">PROTECT</span>
        </button>
        <button class="quickslot @(pietyActive ? "qs-equipped" : "") @(noPrayer ? "qs-spec-depleted" : "")"
                title="piety"
                disabled="@Disabled"
                @onclick='() => Fire("piety")'>
            <span class="qs-icon">⚡</span>
            <span class="qs-label">PIETY</span>
        </button>
    }
    @foreach (var slot in ActiveFixedSlots)
    {
        var slotLocal = slot;
        <button class="quickslot" title="@slot.Command" disabled="@Disabled" @onclick="() => Fire(slotLocal.Command)">
            <span class="qs-icon">@slot.Icon</span>
            <span class="qs-label">@slot.Label</span>
        </button>
    }
</div>

@code {
    [Parameter] public GameState? State { get; set; }
    [Parameter] public EventCallback<string> OnCommand { get; set; }
    [Parameter] public bool Disabled { get; set; }

    private static readonly Dictionary<string, string> _shorthands = new()
    {
        ["armadyl_godsword"]   = "ags",
        ["bandos_godsword"]    = "bgs",
        ["zamorak_godsword"]   = "zgs",
        ["saradomin_godsword"] = "sgs",
        ["dragon_dagger"]      = "dds",
        ["dragon_claws"]       = "claws",
        ["abyssal_whip"]       = "whip",
        ["scythe_of_vitur"]    = "scythe",
        ["corrupted_whip"]     = "cwhip",
    };

    private static readonly string[] _weaponOrder =
    [
        "rune_scimitar", "dragon_scimitar", "dragon_dagger", "abyssal_whip",
        "armadyl_sword", "dragon_claws", "bandos_godsword", "zamorak_godsword",
        "saradomin_godsword", "armadyl_godsword", "scythe_of_vitur", "corrupted_whip",
    ];

    private static readonly HashSet<string> _knownWeaponIds = new(_weaponOrder);

    private static readonly Dictionary<string, int> _specCosts = new()
    {
        ["dragon_dagger"]      = 25,
        ["corrupted_whip"]     = 25,
        ["dragon_claws"]       = 50,
        ["bandos_godsword"]    = 50,
        ["zamorak_godsword"]   = 50,
        ["saradomin_godsword"] = 50,
        ["armadyl_godsword"]   = 50,
        ["scythe_of_vitur"]    = 100,
    };

    private static readonly QuickSlotDefinition[] _combatSlots = [];

    private static readonly QuickSlotDefinition[] _utilitySlots =
    [
        new("🏪", "Shop",    "shop"),
        new("📜", "Stats",   "stats"),
        new("👁", "Inspect", "inspect npc"),
        new("⚔", "NPCs",    "npcs"),
    ];

    private IEnumerable<QuickSlotDefinition> ActiveFixedSlots =>
        State?.InDuel == true ? _combatSlots : _utilitySlots;

    private bool SpecDepleted(string weaponId) =>
        _specCosts.TryGetValue(weaponId, out int cost) &&
        (State?.Player?.SpecialEnergy ?? 100) < cost;

    private IEnumerable<WeaponSlotDef> WeaponSlots()
    {
        if (State?.Player is not { } player) yield break;

        var equippedId = player.GetEquippedWeaponId();

        if (equippedId is not null && _knownWeaponIds.Contains(equippedId))
            yield return MakeWeaponSlot(equippedId);

        foreach (var id in _weaponOrder)
        {
            if (id == equippedId) continue;
            if (player.Inventory.Contains(id))
                yield return MakeWeaponSlot(id);
        }
    }

    private static WeaponSlotDef MakeWeaponSlot(string weaponId)
    {
        var shorthand = _shorthands.TryGetValue(weaponId, out var sh) ? sh : null;
        var cmd = shorthand ?? weaponId;
        var label = (shorthand ?? weaponId.Replace("_", " ")).ToUpperInvariant();
        return new WeaponSlotDef(weaponId, label, cmd);
    }

    private async Task Fire(string command) => await OnCommand.InvokeAsync(command);

    private sealed record QuickSlotDefinition(string Icon, string Label, string Command);
    private sealed record WeaponSlotDef(string WeaponId, string Label, string Command);
}
