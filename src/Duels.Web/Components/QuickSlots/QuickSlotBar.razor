@using Duels.Application.GameSession
@using Duels.Application.Commands
@using Duels.Domain.ValueObjects
@using Duels.Domain.Entities
@inject Duels.Web.Services.GameService GameSvc

<div class="quickslot-bar">
    @{
        var weaponSlots   = WeaponSlots().ToList();
        var activeProt    = State?.Player?.ActiveProtection ?? ProtectionPrayer.None;
        var pietyActive   = State?.Player?.PietyActive == true;
        var noPrayer      = (State?.Player?.PrayerPoints ?? 0) <= 0;
    }
    @if (State?.InDuel == true)
    {
        @if (weaponSlots.Count == 0)
        {
            <button class="quickslot qs-primary" title="Attack" disabled="@_busy" @onclick="Attack">
                <span class="qs-icon">⚔</span>
                <span class="qs-label">ATTACK</span>
            </button>
        }
        else
        {
            @foreach (var slot in weaponSlots)
            {
                var depleted  = SpecDepleted(slot.WeaponId);
                var slotLocal = slot;
                <button class="quickslot @(slot.IsPrimary ? "qs-primary" : "") @(slot.IsQueued ? "qs-queued" : "") @(depleted ? "qs-spec-depleted" : "")"
                        title="@slot.Label"
                        disabled="@_busy"
                        @onclick="() => WeaponShortcut(slotLocal.WeaponId)">
                    @if (_specCosts.TryGetValue(slot.WeaponId, out int cost))
                    {
                        <span class="qs-spec-badge">@cost%</span>
                    }
                    <span class="qs-icon">⚔</span>
                    <span class="qs-label">@slot.Label</span>
                </button>
            }
        }

        <button class="quickslot @(activeProt == ProtectionPrayer.Melee ? "qs-active" : "") @(noPrayer ? "qs-spec-depleted" : "")"
                title="Protect from Melee"
                disabled="@_busy"
                @onclick='() => Protect("protect_melee")'>
            <span class="qs-icon">⛉</span>
            <span class="qs-label">P.MELEE</span>
        </button>
        <button class="quickslot @(activeProt == ProtectionPrayer.Range ? "qs-active" : "") @(noPrayer ? "qs-spec-depleted" : "")"
                title="Protect from Ranged"
                disabled="@_busy"
                @onclick='() => Protect("protect_range")'>
            <span class="qs-icon">➶</span>
            <span class="qs-label">P.RANGE</span>
        </button>
        <button class="quickslot @(activeProt == ProtectionPrayer.Magic ? "qs-active" : "") @(noPrayer ? "qs-spec-depleted" : "")"
                title="Protect from Magic"
                disabled="@_busy"
                @onclick='() => Protect("protect_magic")'>
            <span class="qs-icon">✦</span>
            <span class="qs-label">P.MAGIC</span>
        </button>
        <button class="quickslot @(pietyActive ? "qs-active" : "") @(noPrayer ? "qs-spec-depleted" : "")"
                title="Piety"
                disabled="@_busy"
                @onclick="Piety">
            <span class="qs-icon">⚡</span>
            <span class="qs-label">PIETY</span>
        </button>
        <button class="quickslot" title="Cycle combat style" disabled="@_busy" @onclick="CycleStyle">
            <span class="qs-icon">🎯</span>
            <span class="qs-label">@CurrentStyleLabel</span>
        </button>
    }
    else
    {
        <button class="quickslot" title="Cycle combat style" disabled="@_busy" @onclick="CycleStyle">
            <span class="qs-icon">🎯</span>
            <span class="qs-label">@CurrentStyleLabel</span>
        </button>
        <button class="quickslot" title="Shop" @onclick="() => OnOpenShop.InvokeAsync()">
            <span class="qs-icon">🏪</span>
            <span class="qs-label">SHOP</span>
        </button>
        <button class="quickslot" title="Stats" disabled="@_busy" @onclick="Stats">
            <span class="qs-icon">📜</span>
            <span class="qs-label">STATS</span>
        </button>
        <button class="quickslot" title="Inspect enemy" disabled="@_busy" @onclick="InspectNpc">
            <span class="qs-icon">👁</span>
            <span class="qs-label">INSPECT</span>
        </button>
        <button class="quickslot" title="Duel Arena" @onclick="() => OnOpenLadder.InvokeAsync()">
            <span class="qs-icon">⚔</span>
            <span class="qs-label">ARENA</span>
        </button>
    }
</div>

@code {
    [Parameter] public GameState? State { get; set; }
    [Parameter] public EventCallback OnOpenShop { get; set; }
    [Parameter] public EventCallback OnOpenLadder { get; set; }

    private bool _busy;

    private static readonly Dictionary<string, string> _shorthands = new()
    {
        ["armadyl_godsword"]   = "AGS",
        ["bandos_godsword"]    = "BGS",
        ["zamorak_godsword"]   = "ZGS",
        ["saradomin_godsword"] = "SGS",
        ["dragon_dagger"]      = "DDS",
        ["dragon_claws"]       = "CLAWS",
        ["abyssal_whip"]       = "WHIP",
        ["scythe_of_vitur"]    = "SCYTHE",
        ["corrupted_whip"]     = "C.WHIP",
        ["granite_maul"]       = "G.MAUL",
        ["abyssal_bludgeon"]   = "BLUDGN",
        ["elder_maul"]         = "E.MAUL",
        ["zamorakian_hasta"]   = "HASTA",
        ["ghrazi_rapier"]      = "RAPIER",
    };

    private static readonly string[] _weaponOrder =
    [
        "rune_scimitar", "dragon_scimitar", "dragon_dagger", "granite_maul",
        "abyssal_whip", "zamorakian_hasta", "armadyl_sword", "dragon_claws",
        "abyssal_bludgeon", "bandos_godsword", "zamorak_godsword", "ghrazi_rapier",
        "saradomin_godsword", "armadyl_godsword", "elder_maul", "scythe_of_vitur",
        "corrupted_whip",
    ];

    private static readonly HashSet<string> _knownWeaponIds = new(_weaponOrder);

    private static readonly Dictionary<string, int> _specCosts = new()
    {
        ["dragon_dagger"]      = 25,
        ["corrupted_whip"]     = 25,
        ["dragon_claws"]       = 50,
        ["bandos_godsword"]    = 50,
        ["zamorak_godsword"]   = 50,
        ["saradomin_godsword"] = 50,
        ["armadyl_godsword"]   = 50,
        ["granite_maul"]       = 50,
        ["abyssal_bludgeon"]   = 50,
        ["elder_maul"]         = 50,
        ["scythe_of_vitur"]    = 100,
    };

    private bool SpecDepleted(string weaponId) =>
        _specCosts.TryGetValue(weaponId, out int cost) &&
        (State?.Player?.SpecialEnergy ?? 100) < cost;

    private IEnumerable<WeaponSlotDef> WeaponSlots()
    {
        if (State?.Player is not { } player) yield break;

        var equippedId = player.GetEquippedWeaponId();
        // Primary = the weapon we auto-attack with (or revert-to weapon when a spec is queued)
        var primaryId  = State?.RevertWeaponId ?? equippedId;
        // Queued  = the spec weapon temporarily equipped this tick only
        var queuedId   = State?.RevertWeaponId != null ? equippedId : null;

        // Slot 1: primary (locked, always first)
        if (primaryId is not null && _knownWeaponIds.Contains(primaryId))
            yield return MakeSlot(primaryId, isPrimary: true, isQueued: false);

        // Slot 2: queued spec weapon (if different)
        if (queuedId is not null && queuedId != primaryId && _knownWeaponIds.Contains(queuedId))
            yield return MakeSlot(queuedId, isPrimary: false, isQueued: true);

        // Remaining: other weapons in inventory
        foreach (var id in _weaponOrder)
        {
            if (id == primaryId || id == queuedId) continue;
            if (player.Inventory.Contains(id))
                yield return MakeSlot(id, isPrimary: false, isQueued: false);
        }
    }

    private static WeaponSlotDef MakeSlot(string weaponId, bool isPrimary, bool isQueued)
    {
        var label = _shorthands.TryGetValue(weaponId, out var sh)
            ? sh
            : weaponId.Replace("_", " ").ToUpperInvariant();
        return new WeaponSlotDef(weaponId, label, isPrimary, isQueued);
    }

    private async Task Run(Func<Task> action)
    {
        if (_busy || GameSvc.PlayerId is null) return;
        _busy = true;
        StateHasChanged();
        try { await action(); }
        finally { _busy = false; }
    }

    private string CurrentStyleLabel => State?.Player?.ChosenStyle switch
    {
        AttackStyle.Aggressive => "AGG",
        AttackStyle.Defensive  => "DEF",
        _                      => "ACC",
    };

    private Task CycleStyle()
    {
        var next = State?.Player?.ChosenStyle switch
        {
            AttackStyle.Accurate   => AttackStyle.Aggressive,
            AttackStyle.Aggressive => AttackStyle.Defensive,
            _                      => AttackStyle.Accurate,
        };
        return Run(() => GameSvc.DispatchAsync(new SetStyleCommand(GameSvc.PlayerId!, next)));
    }

    private Task Attack()                   => Run(() => GameSvc.DispatchAsync(new AttackCommand(GameSvc.PlayerId!, AttackStyle.Accurate)));
    private Task WeaponShortcut(string id)  => Run(() => GameSvc.DispatchAsync(new WeaponShortcutCommand(GameSvc.PlayerId!, id)));
    private Task Protect(string prayer)     => Run(() => GameSvc.DispatchAsync(new PrayerCommand(GameSvc.PlayerId!, prayer)));
    private Task Piety()                    => Run(() => GameSvc.DispatchAsync(new PrayerCommand(GameSvc.PlayerId!, "piety")));
    private Task Stats()                    => Run(() => GameSvc.DispatchAsync(new InspectCommand(GameSvc.PlayerId!, "me")));
    private Task InspectNpc()              => Run(() => GameSvc.DispatchAsync(new InspectCommand(GameSvc.PlayerId!, "npc")));

    private sealed record WeaponSlotDef(string WeaponId, string Label, bool IsPrimary, bool IsQueued);
}
