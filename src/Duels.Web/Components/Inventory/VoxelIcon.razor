@inject IJSRuntime JS

@* Pixel-art icon for an item with a voxel model; renders nothing when the
   item has no model so callers keep their text fallback. *@
@if (_src is not null)
{
    <img class="voxel-icon" src="@_src" alt="" style="width:@(Size)px;height:@(Size)px" />
}

@code {
    [Parameter] public string? ItemId { get; set; }
    [Parameter] public int Size { get; set; } = 24;

    private string? _src;
    private string? _loadedFor;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (ItemId == _loadedFor) return;
        _loadedFor = ItemId;

        string? src = null;
        if (ItemId is not null)
        {
            try { src = await JS.InvokeAsync<string?>("voxel.itemIcon", ItemId, Size); }
            catch { /* JS not ready / teardown — keep text fallback */ }
        }
        if (src != _src)
        {
            _src = src;
            StateHasChanged();
        }
    }
}
