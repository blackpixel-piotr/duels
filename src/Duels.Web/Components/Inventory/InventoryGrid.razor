@using Duels.Application.GameSession
@using Duels.Application.Abstractions
@using Duels.Domain.Entities
@inject IItemRepository ItemRepo

<div class="inventory-panel">
    <div class="panel-title">Inventory</div>
    <div class="inv-grid">
        @foreach (var itemId in Items)
        {
            <button class="inv-slot @SlotClass(itemId)" title="@SlotTitle(itemId)" @onclick="() => UseItem(itemId)">
                <VoxelIcon ItemId="@itemId" Size="28" />
                <span class="inv-item-name">@ShortName(itemId)</span>
            </button>
        }
        @for (int i = Items.Count; i < Player.BagCapacity; i++)
        {
            <div class="inv-slot inv-empty"></div>
        }
    </div>
</div>

@code {
    [Parameter] public GameState? State { get; set; }

    // M2 Workstream C.3 (UI bible §8.1 compare flow): tapping an item shows
    // its compare card instead of equipping instantly; the parent (BagSheet)
    // owns the card and dispatches the actual EquipItemCommand from it.
    [Parameter] public EventCallback<string> OnSelectItem { get; set; }

    // Flasks (m1-plan Workstream E) aren't tap-to-compare from the bag —
    // they're bound to the belt in the Loadout Editor and sipped in-duel.
    private static readonly HashSet<string> _flasks = ["flask_health", "flask_prayer", "flask_rotward"];

    private IReadOnlyList<string> Items => State?.Player?.Inventory ?? [];

    private async Task UseItem(string itemId)
    {
        if (_flasks.Contains(itemId)) return;
        await OnSelectItem.InvokeAsync(itemId);
    }

    private static string SlotClass(string id) => _flasks.Contains(id) ? "inv-flask" : "";

    private string SlotTitle(string id)
    {
        if (_flasks.Contains(id)) return $"{ShortName(id)} — bind in the Loadout Editor";
        // Items doc §1: Power = average damage, max hit = 2×Power.
        int? power = ItemRepo.GetWeapon(id)?.Doc.Power;
        string stats = power is { } p ? $" · Power {p} · Max hit {p * 2}" : "";
        return $"{ShortName(id)} — tap to compare{stats}";
    }

    private static string ShortName(string id) =>
        string.Join(" ", id.Split('_').Select(w => char.ToUpper(w[0]) + w[1..]));
}
