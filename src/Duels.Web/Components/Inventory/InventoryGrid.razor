@using Duels.Application.GameSession
@using Duels.Application.Commands
@inject Duels.Web.Services.GameService GameSvc

<div class="inventory-panel">
    <div class="panel-title">Inventory</div>
    <div class="inv-grid">
        @foreach (var itemId in Items)
        {
            <button class="inv-slot @SlotClass(itemId)" title="@SlotTitle(itemId)" @onclick="() => UseItem(itemId)">
                <VoxelIcon ItemId="@itemId" Size="28" />
                <span class="inv-item-name">@ShortName(itemId)</span>
            </button>
        }
        @for (int i = Items.Count; i < 28; i++)
        {
            <div class="inv-slot inv-empty"></div>
        }
    </div>
</div>

@code {
    [Parameter] public GameState? State { get; set; }

    // Flasks (m1-plan Workstream E) aren't tap-to-consume from the bag —
    // they're bound to the belt in the Loadout Editor and sipped in-duel.
    private static readonly HashSet<string> _flasks = ["flask_health", "flask_prayer"];

    private IReadOnlyList<string> Items => State?.Player?.Inventory ?? [];

    private async Task UseItem(string itemId)
    {
        if (GameSvc.PlayerId is null || _flasks.Contains(itemId)) return;
        await GameSvc.DispatchAsync(new EquipItemCommand(GameSvc.PlayerId!, itemId));
    }

    private static string SlotClass(string id) => _flasks.Contains(id) ? "inv-flask" : "";

    private static string SlotTitle(string id) =>
        _flasks.Contains(id) ? $"{ShortName(id)} — bind in the Loadout Editor"
        : $"{ShortName(id)} — tap to equip";

    private static string ShortName(string id) =>
        string.Join(" ", id.Split('_').Select(w => char.ToUpper(w[0]) + w[1..]));
}
