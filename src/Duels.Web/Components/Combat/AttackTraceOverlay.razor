@implements IDisposable
@inject IJSRuntime JS

<div class="trace-overlay"
     @ontouchstart="OnTouchStart" @ontouchstart:preventDefault
     @ontouchmove="OnTouchMove"   @ontouchmove:preventDefault
     @ontouchend="OnTouchEnd"
     @onmousedown="OnMouseDown"
     @onmousemove="OnMouseMove"
     @onmouseup="OnMouseUp">
    <div class="trace-container">
        <div class="trace-label">@WeaponPaths.LabelForWeapon(WeaponId)</div>
        <svg id="trace-svg" class="trace-svg" viewBox="0 0 400 300" xmlns="http://www.w3.org/2000/svg">
            <path class="ideal" d="@_path" />
            @if (_svgTracedPoints.Count > 1)
            {
                <polyline class="traced" points="@TracedPolyline" />
            }
            @if (!_completed)
            {
                <circle class="guide-dot" style="offset-path:path('@_path');animation:travel @(_traceDuration)s linear forwards" cx="0" cy="0" r="14" />
            }
        </svg>
        @if (_accuracyResult.HasValue)
        {
            <div class="accuracy-flash @AccuracyClass(_accuracyResult.Value)">@_accuracyResult.Value%</div>
        }
        <div class="trace-hint">Swipe along the glowing path</div>
    </div>
</div>

@code {
    [Parameter] public string WeaponId { get; set; } = "";
    [Parameter] public EventCallback<int> OnComplete { get; set; }

    private string _path = "";
    private double _traceDuration = 2.0;

    // Points in SVG coordinate space
    private readonly List<(double X, double Y)> _svgTracedPoints = new();
    private int? _accuracyResult;
    private bool _completed;
    private bool _mouseDown;

    // SVG element bounding rect (client space) for coordinate mapping
    private double _svgLeft, _svgTop, _svgWidth = 400, _svgHeight = 300;

    private DotNetObjectReference<AttackTraceOverlay>? _selfRef;

    protected override void OnParametersSet()
    {
        _path = WeaponPaths.ForWeapon(WeaponId);
        _traceDuration = WeaponId switch
        {
            "dragon_claws"    => 2.2,
            "scythe_of_vitur" => 2.5,
            "dragon_dagger"   => 2.2,
            _                 => 2.0,
        };
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _selfRef = DotNetObjectReference.Create(this);
            var rect = await JS.InvokeAsync<double[]>("getSvgRect", "trace-svg");
            if (rect is { Length: >= 4 })
            {
                _svgLeft = rect[0]; _svgTop = rect[1];
                _svgWidth = rect[2]; _svgHeight = rect[3];
            }
            await JS.InvokeVoidAsync("scheduleTraceTimeout", _selfRef, (int)((_traceDuration + 0.8) * 1000));
        }
    }

    private (double SvgX, double SvgY) ToSvg(double clientX, double clientY)
    {
        double w = _svgWidth  <= 0 ? 400 : _svgWidth;
        double h = _svgHeight <= 0 ? 300 : _svgHeight;
        return ((clientX - _svgLeft) / w * 400.0,
                (clientY - _svgTop)  / h * 300.0);
    }

    private void OnTouchStart(TouchEventArgs e) { _svgTracedPoints.Clear(); _accuracyResult = null; _completed = false; }
    private void OnTouchMove(TouchEventArgs e)
    {
        if (_completed) return;
        foreach (var t in e.ChangedTouches)
        {
            var (sx, sy) = ToSvg(t.ClientX, t.ClientY);
            _svgTracedPoints.Add((sx, sy));
        }
        StateHasChanged();
    }
    private async Task OnTouchEnd(TouchEventArgs e) { if (!_completed) await Finish(); }

    private void OnMouseDown(MouseEventArgs e)
    {
        _mouseDown = true;
        _svgTracedPoints.Clear();
        _accuracyResult = null;
        _completed = false;
    }
    private void OnMouseMove(MouseEventArgs e)
    {
        if (!_mouseDown || _completed) return;
        var (sx, sy) = ToSvg(e.ClientX, e.ClientY);
        _svgTracedPoints.Add((sx, sy));
        StateHasChanged();
    }
    private async Task OnMouseUp(MouseEventArgs e) { if (_mouseDown && !_completed) { _mouseDown = false; await Finish(); } }

    [JSInvokable]
    public async Task TimerExpired() { if (!_completed) await Finish(); }

    private async Task Finish()
    {
        _completed = true;
        int accuracy = ComputeAccuracy();
        _accuracyResult = accuracy;
        StateHasChanged();
        await Task.Delay(900);
        await OnComplete.InvokeAsync(accuracy);
    }

    private int ComputeAccuracy()
    {
        if (_svgTracedPoints.Count == 0) return 0;

        var ideal = SampleIdealPoints(60);
        const double Threshold = 55.0; // SVG units

        int hits = _svgTracedPoints.Count(fp => ideal.Any(ip => Dist(fp, ip) < Threshold));
        return Math.Clamp(hits * 100 / _svgTracedPoints.Count, 0, 100);
    }

    private List<(double X, double Y)> SampleIdealPoints(int n)
    {
        var pts = ExtractPathPoints(_path);
        if (pts.Count < 2) return pts;

        double totalLen = 0;
        for (int i = 1; i < pts.Count; i++) totalLen += Dist(pts[i - 1], pts[i]);

        var result = new List<(double, double)>(n) { pts[0] };
        double acc = 0;
        int idx = 0;
        for (int s = 1; s < n; s++)
        {
            double target = s * totalLen / n;
            while (idx + 1 < pts.Count)
            {
                double seg = Dist(pts[idx], pts[idx + 1]);
                if (acc + seg >= target)
                {
                    double t = (target - acc) / seg;
                    result.Add((pts[idx].X + t * (pts[idx + 1].X - pts[idx].X),
                                pts[idx].Y + t * (pts[idx + 1].Y - pts[idx].Y)));
                    break;
                }
                acc += seg; idx++;
            }
        }
        result.Add(pts[^1]);
        return result;
    }

    private static List<(double X, double Y)> ExtractPathPoints(string path)
    {
        var pts = new List<(double X, double Y)>();
        var tokens = path.Split(new[] { ' ', ',' }, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        double? pending = null;
        foreach (var tok in tokens)
        {
            if (tok.Length == 1 && char.IsLetter(tok[0])) { pending = null; continue; }
            if (double.TryParse(tok, System.Globalization.NumberStyles.Float,
                System.Globalization.CultureInfo.InvariantCulture, out double v))
            {
                if (pending is null) pending = v;
                else { pts.Add((pending.Value, v)); pending = null; }
            }
        }
        return pts;
    }

    private static double Dist((double X, double Y) a, (double X, double Y) b)
    {
        double dx = a.X - b.X, dy = a.Y - b.Y;
        return Math.Sqrt(dx * dx + dy * dy);
    }

    private string TracedPolyline =>
        string.Join(" ", _svgTracedPoints.Select(p => $"{p.X:F0},{p.Y:F0}"));

    private static string AccuracyClass(int acc) =>
        acc >= 80 ? "acc-great" : acc >= 40 ? "acc-ok" : "acc-miss";

    public void Dispose() => _selfRef?.Dispose();
}
