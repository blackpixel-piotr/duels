@using Duels.Application.GameSession
@using Duels.Domain.ValueObjects

@if (State?.InDuel == true && State.Player is { } p && State.ActiveNpc is { } npc)
{
    <div class="combat-stage">
        <div class="stage-npc">
            <div class="stage-npc-name glow-red">
                @{ var styleKey = npc.CurrentAttackType; }
                <span @key="styleKey" class="style-badge style-badge-@StyleClass(styleKey)"
                      title="Incoming: @StyleName(styleKey)">@StyleIcon(styleKey)</span>
                @npc.Template.Name
            </div>
            @if (BannerEntry is { } banner)
            {
                <div class="stage-banner">@banner.Message</div>
            }
            <div class="hitsplat-zone hitsplat-zone-right" id="zone-npc"></div>
            <div class="stage-hp-row">
                <div class="hp-bar-wrap"><div class="hp-bar npc-hp-bar" style="width: @NpcHpPct%"></div></div>
                <span class="stage-hp-val">@npc.CurrentHp/@npc.MaxHp</span>
            </div>
        </div>

        <div class="stage-player-row">
            <div class="hitsplat-zone" id="zone-player"></div>
            <span class="stage-player-name">@p.Name</span>
            <div class="stage-mini-bars">
                <div class="mini-bar-wrap"><div class="hp-bar" style="width: @PlayerHpPct%"></div></div>
                <div class="mini-bar-wrap"><div class="spec-bar" style="width: @p.SpecialEnergy%"></div></div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public GameState? State { get; set; }

    private int PlayerHpPct =>
        State?.Player is { } p && p.MaxHp > 0
            ? (int)(p.CurrentHp * 100.0 / p.MaxHp) : 0;

    private int NpcHpPct =>
        State?.ActiveNpc is { } n && n.MaxHp > 0
            ? (int)(n.CurrentHp * 100.0 / n.MaxHp) : 0;

    // Telegraph banner: show the newest boss-special warning for a few ticks
    // after it's logged — pure render-time filter, no extra state needed.
    private CombatLogEntry? BannerEntry =>
        State?.CombatLog.LastOrDefault(e =>
            e.Kind == LogEntryKind.BossSpecial &&
            (DateTimeOffset.UtcNow - e.Timestamp) < TimeSpan.FromSeconds(2.4));

    private static string StyleClass(AttackType t) => t switch
    {
        AttackType.Ranged => "ranged",
        AttackType.Magic  => "magic",
        _                 => "melee",
    };

    private static string StyleIcon(AttackType t) => t switch
    {
        AttackType.Ranged => "➶",
        AttackType.Magic  => "✦",
        _                 => "⚔",
    };

    private static string StyleName(AttackType t) => t switch
    {
        AttackType.Ranged => "Ranged — pray ⛉R",
        AttackType.Magic  => "Magic — pray ⛉MG",
        _                 => "Melee — pray ⛉M",
    };
}
