@using Duels.Application.GameSession
@using Duels.Application.Abstractions
@using Duels.Application.Commands
@using Duels.Domain.ValueObjects
@inject IJSRuntime JS
@inject IItemRepository ItemRepo
@inject Duels.Web.Services.GameService GameSvc
@inject Duels.Application.Services.GameTickService TickService
@implements IAsyncDisposable

@* Three-quarter battle scene with a player-centered, drag-to-rotate camera.
   Taps click through to the sim (ground = walk order, enemy = engage).
   Stays mounted through the whole duel and the result overlay — after a duel
   ends ActiveNpc is null, so enemy display fields are cached. *@
<div class="battle-scene" id="battle-scene">
    <canvas id="battle-canvas" width="260" height="200"></canvas>

    <div class="battle-box battle-box-enemy">
        <div class="battle-box-name glow-red">
            @if (State?.ActiveNpc is { } liveNpc)
            {
                var styleKey = liveNpc.CurrentAttackType;
                <span @key="styleKey" class="style-badge style-badge-@StyleClass(styleKey)"
                      title="Incoming: @StyleName(styleKey)">@StyleIcon(styleKey)</span>
            }
            @_enemyName
        </div>
        <div class="battle-box-bars">
            <div class="hp-bar-wrap"><div class="hp-bar npc-hp-bar" style="width: @EnemyHpPct%"></div></div>
            <span class="battle-box-val">@EnemyHp/@_enemyMaxHp</span>
        </div>
    </div>

    <div class="battle-box battle-box-player">
        <div class="battle-box-name glow-amber">@State?.Player?.Name</div>
        <div class="battle-box-bars">
            <div class="hp-bar-wrap"><div class="hp-bar" style="width: @PlayerHpPct%"></div></div>
            <span class="battle-box-val">@State?.Player?.CurrentHp/@State?.Player?.MaxHp</span>
        </div>
        <div class="battle-box-bars">
            <div class="mini-bar-wrap"><div class="prayer-bar" style="width: @PlayerPrayerPct%"></div></div>
            <div class="mini-bar-wrap"><div class="spec-bar" style="width: @(State?.Player?.SpecialEnergy ?? 0)%"></div></div>
        </div>
    </div>

    @if (BubbleText is { } bubble)
    {
        <div class="telegraph-bubble">@bubble</div>
    }
    @if (State?.TestScene == true)
    {
        <button class="freeze-btn @(EnemyFrozen ? "freeze-btn-on" : "")"
                @onclick="ToggleFreezeEnemy">
            @(EnemyFrozen ? "UNFREEZE" : "FREEZE ENEMY")
        </button>

        <button class="cam-toggle-btn" @onclick="() => _camPanelOpen = !_camPanelOpen">
            @(_camPanelOpen ? "CAM ▲" : "CAM ▼")
        </button>
        @if (_camPanelOpen)
        {
            <div class="cam-debug-panel">
                <div class="cam-debug-row">
                    <label>FOV <span>@_camFov.ToString("0")</span></label>
                    <input type="range" min="10" max="90" step="1"
                           value="@_camFov" @oninput="OnCamFovInput" />
                </div>
                <div class="cam-debug-row">
                    <label>Depth squash <span>@_camTilt.ToString("0.00")</span></label>
                    <input type="range" min="0" max="1" step="0.01"
                           value="@_camTilt" @oninput="OnCamTiltInput" />
                </div>
                <div class="cam-debug-row">
                    <label>Pitch <span>@_camPitch.ToString("0.00")</span></label>
                    <input type="range" min="0.1" max="2.2" step="0.01"
                           value="@_camPitch" @oninput="OnCamPitchInput" />
                </div>
                <div class="cam-debug-row">
                    <label>Zoom <span>@_camZoom.ToString("0.00")</span></label>
                    <input type="range" min="0.2" max="4" step="0.01"
                           value="@_camZoom" @oninput="OnCamZoomInput" />
                </div>
                <button class="cam-debug-reset" @onclick="ResetCameraDebug">Reset</button>
            </div>
        }
    }
</div>

@code {
    [Parameter] public GameState? State { get; set; }
    [Parameter] public IReadOnlyList<CombatLogEntry> LogEntries { get; set; } = [];
    [Parameter] public bool EnemyDead { get; set; }
    [Parameter] public bool PlayerDead { get; set; }
    [Parameter] public string? WeaponId { get; set; }

    private int _lastCount;
    private bool _inited;
    private DotNetObjectReference<BattleScene>? _selfRef;
    private bool _lastTelegraph;
    private string? _lastWindup;
    private bool? _lastHoldPosition;
    private string? _lastWeapon;
    private bool _deathFired;
    private string? _enemyId;
    private string _enemyName = "";
    private int _enemyMaxHp = 1;
    private bool EnemyFrozen => State?.EnemyFrozen ?? false;

    // Admin camera debug panel (test fights only) — mirrors the JS defaults
    // in voxel.js (CAM_FOV, TILT, POS_TILT, camZoom=1) so the sliders start
    // in sync with what's already on screen.
    private bool _camPanelOpen;
    private double _camFov = 25;
    private double _camTilt = 0.3;
    private double _camPitch = 0.7;
    private double _camZoom = 1.0;

    private string? _lastOverheads;

    protected override void OnParametersSet()
    {
        // Cache enemy identity so the death frame still renders after
        // EndDuel() nulls ActiveNpc.
        if (State?.ActiveNpc is { } npc)
        {
            _enemyId = npc.Template.Id;
            _enemyName = npc.Template.Name;
            _enemyMaxHp = npc.MaxHp;
        }
    }

    private int EnemyHp => EnemyDead ? 0 : State?.ActiveNpc?.CurrentHp ?? 0;
    private int EnemyHpPct => _enemyMaxHp > 0 ? EnemyHp * 100 / _enemyMaxHp : 0;

    private int PlayerHpPct =>
        State?.Player is { } p && p.MaxHp > 0 ? (int)(p.CurrentHp * 100.0 / p.MaxHp) : 0;

    // PrayerPoints caps at 99, not 100 — normalize for the bar fill.
    private int PlayerPrayerPct => (int)((State?.Player?.PrayerPoints ?? 0) * 100.0 / 99);

    // Armed special persists until it fires; style-rotation and other warnings
    // fall back to the newest BossSpecial log line for a short window.
    private string? BubbleText =>
        State?.ActiveNpc?.PendingSpecial?.WarningText
        ?? State?.CombatLog.LastOrDefault(e =>
            e.Kind == LogEntryKind.BossSpecial &&
            (DateTimeOffset.UtcNow - e.Timestamp) < TimeSpan.FromSeconds(2.4))?.Message;

    // Overhead prayer icons are drawn in-canvas by voxel.js (pixel art);
    // these just name the active icon per side.
    private string? PlayerOverhead => State?.Player switch
    {
        { ActiveProtection: ProtectionPrayer.Melee } => "melee",
        { ActiveProtection: ProtectionPrayer.Range } => "ranged",
        { ActiveProtection: ProtectionPrayer.Magic } => "magic",
        { PietyActive: true }                        => "piety",
        _ => null,
    };

    private string? NpcOverhead =>
        State?.ActiveNpc is { WarlordPrayerActive: true } ? "melee" : null;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Seed the log cursor first: entries that existed before the scene
            // mounted must not fire splats/animations.
            _lastCount = LogEntries.Count;
            _selfRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("voxel.initBattle", "battle-canvas", new
            {
                playerUrl = "assets/player_sakuna.vox",
                playerRigId = "player_sakuna",
                enemyId = _enemyId,
                scene = State?.TestScene == true ? "field" : "arena",
                dotnetRef = _selfRef,
            });
            _lastWeapon = WeaponId;
            await JS.InvokeVoidAsync("voxel.setBattleWeapon", "battle-canvas", WeaponId);
            // Solid obstacles the movers pathfind around — placed as low props the
            // scene renders on those tiles. Fixed per duel, so send once on mount.
            await JS.InvokeVoidAsync("voxel.setBattleObstacles", "battle-canvas",
                State?.Obstacles.Select(o => new { x = o.X, z = o.Z }).ToArray() ?? []);
            // Landscape fight auto-rotates in portrait; keep canvas taps mapped.
            await JS.InvokeVoidAsync("voxel.watchOrientation", "battle-canvas");
            _inited = true;
            return;
        }
        if (!_inited) return;

        // RETRY rematches reuse the mounted scene — restore the crumbled loser.
        if (State?.InDuel == true && _deathFired)
        {
            _deathFired = false;
            await JS.InvokeVoidAsync("voxel.resetBattle", "battle-canvas");
        }

        // Endless waves swap the enemy without remounting the scene.
        if (State?.ActiveNpc is { } npc && npc.Template.Id != _enemyId)
        {
            _enemyId = npc.Template.Id;
            await JS.InvokeVoidAsync("voxel.setBattleEnemy", "battle-canvas", _enemyId);
        }

        // Weapon switches show up in the player's hand.
        if (WeaponId != _lastWeapon)
        {
            _lastWeapon = WeaponId;
            await JS.InvokeVoidAsync("voxel.setBattleWeapon", "battle-canvas", WeaponId);
        }

        // HP fractions drive voxel erosion (damage chips the model, food regrows it).
        await JS.InvokeVoidAsync("voxel.setBattleVitals", "battle-canvas", new
        {
            player = State?.Player is { MaxHp: > 0 } pl ? pl.CurrentHp / (double)pl.MaxHp : 1.0,
            enemy = _enemyMaxHp > 0 ? EnemyHp / (double)_enemyMaxHp : 1.0,
        });

        // Sim tile positions — the scene walks the actors toward these.
        if (State is { } s)
            await JS.InvokeVoidAsync("voxel.setBattlePositions", "battle-canvas", new
            {
                player = new { x = s.PlayerTile.X, z = s.PlayerTile.Z },
                enemy = new { x = s.NpcTile.X, z = s.NpcTile.Z },
            });

        // Overhead prayer icons (drawn in-canvas); send only on change.
        var overheads = $"{PlayerOverhead}|{NpcOverhead}";
        if (overheads != _lastOverheads)
        {
            _lastOverheads = overheads;
            await JS.InvokeVoidAsync("voxel.setBattleOverheads", "battle-canvas",
                new { player = PlayerOverhead, enemy = NpcOverhead });
        }

        var newEntries = LogEntries.Count > _lastCount ? LogEntries.Skip(_lastCount).ToList() : [];
        _lastCount = LogEntries.Count;

        foreach (var e in newEntries)
        {
            // Eating: raise-to-mouth animation with the food in the off-hand.
            if (e.Kind == LogEntryKind.Info && e.Message.StartsWith("You eat the "))
            {
                var rest = e.Message["You eat the ".Length..];
                var dot = rest.IndexOf('.');
                var item = dot > 0 ? rest[..dot] : rest;
                await JS.InvokeVoidAsync("voxel.battleEvent", "battle-canvas",
                    new { type = "playerEat", item });
                continue;
            }
            if (e.Kind is not (LogEntryKind.HitsplatPlayer or LogEntryKind.HitsplatNpc)) continue;
            var parts = e.Message.Split(':');
            int dmg = int.TryParse(parts[0], out var d) ? d : 0;
            string tier = parts.Length > 1 ? parts[1] : "normal";
            // A spec hitsplat carries the weapon it was thrown with (e.g. a dds
            // spec that reverts to the main-hand this same tick) — show that
            // weapon + its animation, not the reverted equipped weapon.
            string? specWeapon = parts.Length > 2 && parts[2].Length > 0 ? parts[2] : null;

            // HitsplatPlayer = damage dealt BY the player → lands on the enemy;
            // HitsplatNpc = damage dealt BY the NPC → lands on the player.
            // (The splat itself is drawn in-canvas by battleEvent's impact.)
            bool onEnemy = e.Kind == LogEntryKind.HitsplatPlayer;

            // DoT ticks aren't attacks — no swing, just the victim's flash.
            if (tier != "poison")
                await JS.InvokeVoidAsync("voxel.battleEvent", "battle-canvas",
                    new
                    {
                        type = onEnemy ? "playerAttack" : "enemyAttack",
                        style = onEnemy ? PlayerStyle() : null,
                        kind = onEnemy ? PlayerKind() : null,
                        tier,   // 'spec' selects the weapon's special-attack flourish
                        weapon = onEnemy ? (specWeapon ?? WeaponId) : null, // spec weapon wins the revert race
                    });
            await JS.InvokeVoidAsync("voxel.battleEvent", "battle-canvas",
                new { type = onEnemy ? "enemyHit" : "playerHit", tier, dmg });
        }

        if (newEntries.Any(e => e.Kind is LogEntryKind.MaxHit or LogEntryKind.SpecHit
                                       or LogEntryKind.Vengeance or LogEntryKind.BossSpecial))
            await JS.InvokeVoidAsync("triggerShake", "battle-scene", 180);

        bool telegraph = State?.ActiveNpc?.PendingSpecial is not null;
        if (telegraph != _lastTelegraph)
        {
            _lastTelegraph = telegraph;
            await JS.InvokeVoidAsync("voxel.setBattleFlags", "battle-canvas", new { telegraph });
        }

        // NpcCooldown == 1 after a tick means the enemy attacks on the next
        // tick (~600ms) — the reaction window prayer flicking will key off.
        // No cue while the NPC is still walking into melee range.
        string? windup =
            State is { InDuel: true, NpcCooldown: 1, NpcInRange: true, ActiveNpc: { } wn } && !EnemyDead && !PlayerDead
                ? StyleClass(wn.CurrentAttackType) : null;
        if (windup != _lastWindup)
        {
            _lastWindup = windup;
            await JS.InvokeVoidAsync("voxel.setBattleFlags", "battle-canvas", new { windup });
        }

        bool holdPosition = State?.HoldPosition ?? false;
        if (holdPosition != _lastHoldPosition)
        {
            _lastHoldPosition = holdPosition;
            await JS.InvokeVoidAsync("voxel.setBattleFlags", "battle-canvas", new { holdPosition });
        }

        if ((EnemyDead || PlayerDead) && !_deathFired)
        {
            _deathFired = true;
            await JS.InvokeVoidAsync("voxel.battleEvent", "battle-canvas",
                new { type = EnemyDead ? "enemyDeath" : "playerDeath" });
        }
    }

    // Scene taps, forwarded from voxel.js: a ground tap orders a walk
    // (disengaging), an enemy tap re-engages the chase.
    private async Task ToggleFreezeEnemy()
    {
        if (GameSvc.PlayerId is { } pid)
            await GameSvc.DispatchAsync(new FreezeEnemyCommand(pid, !EnemyFrozen));
    }

    // Camera debug panel: each slider pushes the full set of four values —
    // voxel.setCameraDebug is idempotent and cheap, so no point diffing.
    private Task OnCamFovInput(ChangeEventArgs e) => SetCamField(e, v => _camFov = v);
    private Task OnCamTiltInput(ChangeEventArgs e) => SetCamField(e, v => _camTilt = v);
    private Task OnCamPitchInput(ChangeEventArgs e) => SetCamField(e, v => _camPitch = v);
    private Task OnCamZoomInput(ChangeEventArgs e) => SetCamField(e, v => _camZoom = v);

    private Task SetCamField(ChangeEventArgs e, Action<double> assign)
    {
        if (double.TryParse(e.Value?.ToString(), out var v)) assign(v);
        return PushCameraDebug();
    }

    private Task PushCameraDebug() =>
        JS.InvokeVoidAsync("voxel.setCameraDebug", "battle-canvas",
            new { fov = _camFov, tilt = _camTilt, pitch = _camPitch, zoom = _camZoom }).AsTask();

    private Task ResetCameraDebug()
    {
        _camFov = 25; _camTilt = 0.3; _camPitch = 0.7; _camZoom = 1.0;
        return PushCameraDebug();
    }

    [JSInvokable]
    public async Task OnGroundClick(int x, int z)
    {
        if (GameSvc.PlayerId is { } pid)
        {
            await GameSvc.DispatchAsync(new MoveToCommand(pid, x, z));
            await TickService.KickMoveAsync(pid); // step on the click, not next tick
        }
    }

    [JSInvokable]
    public async Task OnEnemyClick()
    {
        if (GameSvc.PlayerId is { } pid)
            await GameSvc.DispatchAsync(new EngageCommand(pid));
    }

    // The player's projectile/effect style comes from the equipped weapon.
    private string PlayerStyle() =>
        WeaponId is { } id && ItemRepo.GetWeapon(id) is { } w ? StyleClass(w.AttackType) : "melee";

    // Swing choreography kind: the weapon's AttackType (stab/slash/crush);
    // bare fists punch like a crush. voxel.js applies per-weapon overrides.
    private string PlayerKind() =>
        WeaponId is { } id && ItemRepo.GetWeapon(id) is { } w
            ? w.AttackType.ToString().ToLowerInvariant() : "crush";

    private static string StyleClass(AttackType t) => t switch
    {
        AttackType.Ranged => "ranged",
        AttackType.Magic  => "magic",
        _                 => "melee",
    };

    private static string StyleIcon(AttackType t) => t switch
    {
        AttackType.Ranged => "➶",
        AttackType.Magic  => "✦",
        _                 => "⚔",
    };

    private static string StyleName(AttackType t) => t switch
    {
        AttackType.Ranged => "Ranged — pray ⛉R",
        AttackType.Magic  => "Magic — pray ⛉MG",
        _                 => "Melee — pray ⛉M",
    };

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("voxel.destroyBattle", "battle-canvas"); }
        catch { /* JS runtime tearing down */ }
        _selfRef?.Dispose();
    }
}
