@using Duels.Application.GameSession
@using Duels.Application.Abstractions
@using Duels.Application.Commands
@using Duels.Domain.ValueObjects
@inject IJSRuntime JS
@inject IItemRepository ItemRepo
@inject Duels.Web.Services.GameService GameSvc
@inject Duels.Application.Services.GameTickService TickService
@implements IAsyncDisposable

@* Three-quarter battle scene with a player-centered, drag-to-rotate camera.
   Taps click through to the sim (ground = walk order, enemy = engage).
   Stays mounted through the whole duel and the result overlay — after a duel
   ends ActiveNpc is null, so enemy display fields are cached. *@
<div class="battle-scene" id="battle-scene">
    <canvas id="battle-canvas" width="260" height="200"></canvas>

    <div class="battle-box battle-box-enemy">
        <div class="battle-box-name glow-red">
            @if (ForecastStyle is { } styleKey)
            {
                <span @key="styleKey" class="style-badge style-badge-@StyleClass(styleKey)"
                      title="Incoming: @StyleName(styleKey)">@StyleIcon(styleKey)</span>
            }
            @_enemyName
        </div>
        <div class="battle-box-bars">
            <div class="hp-bar-wrap"><div class="hp-bar npc-hp-bar" style="width: @EnemyHpPct%"></div></div>
            <span class="battle-box-val">@EnemyHp/@_enemyMaxHp</span>
        </div>
    </div>

    <div class="battle-box battle-box-player">
        <div class="battle-box-name glow-amber">@State?.Player?.Name</div>
        <div class="battle-box-bars">
            <div class="hp-bar-wrap"><div class="hp-bar" style="width: @PlayerHpPct%"></div></div>
            <span class="battle-box-val">@State?.Player?.CurrentHp/@State?.Player?.MaxHp</span>
        </div>
        <div class="battle-box-bars">
            <div class="mini-bar-wrap"><div class="prayer-bar" style="width: @PlayerPrayerPct%"></div></div>
            <div class="mini-bar-wrap"><div class="spec-bar" style="width: @(State?.Player?.SpecialEnergy ?? 0)%"></div></div>
        </div>
    </div>

    @if (BubbleText is { } bubble)
    {
        <div class="telegraph-bubble">@bubble</div>
    }
    @* Dev-only per-mechanic kill switches (M1 playtest tooling) — isolate one
       mechanic at a time. Reachable in every M1 fight (all fights are dev
       fights); not gated behind TestScene, which also swaps the scene visual. *@
    <button class="cam-toggle-btn mech-toggle-btn" @onclick="() => _mechPanelOpen = !_mechPanelOpen"
            title="Dev: toggle individual boss mechanics">
        @(_mechPanelOpen ? "MECH ▲" : "MECH ▼")
    </button>
    @if (_mechPanelOpen)
    {
        <div class="cam-debug-panel mech-debug-panel">
            @foreach (var (label, mech) in MechToggles)
            {
                <label class="mech-toggle-row">
                    <input type="checkbox" checked="@(State?.IsMechanicEnabled(mech) ?? true)"
                           @onchange="() => ToggleMechanic(mech)" />
                    <span>@label</span>
                </label>
            }
        </div>
    }
    @if (State?.TestScene == true)
    {
        <button class="freeze-btn @(EnemyFrozen ? "freeze-btn-on" : "")"
                @onclick="ToggleFreezeEnemy">
            @(EnemyFrozen ? "UNFREEZE" : "FREEZE ENEMY")
        </button>

        <button class="cam-toggle-btn" @onclick="() => _camPanelOpen = !_camPanelOpen">
            @(_camPanelOpen ? "CAM ▲" : "CAM ▼")
        </button>
        <button class="cam-toggle-btn move-toggle-btn" @onclick="ToggleMovePanel">
            @(_movePanelOpen ? "MOVE ▲" : "MOVE ▼")
        </button>
        @if (_movePanelOpen)
        {
            <div class="cam-debug-panel move-debug-panel">
                <div class="cam-debug-row">
                    <label>Speed × <span>@_mvSpeed.ToString("0.00")</span></label>
                    <input type="range" min="0.25" max="4" step="0.05"
                           value="@_mvSpeed" @oninput="@(e => OnMoveInput(e, v => _mvSpeed = v))" />
                </div>
                <div class="cam-debug-row">
                    <label>Turn rate <span>@_mvTurn.ToString("0.000")</span></label>
                    <input type="range" min="0.005" max="0.3" step="0.005"
                           value="@_mvTurn" @oninput="@(e => OnMoveInput(e, v => _mvTurn = v))" />
                </div>
                <div class="cam-debug-row">
                    <label>Stride ease-in <span>@_mvIn.ToString("0.000")</span></label>
                    <input type="range" min="0.001" max="0.05" step="0.001"
                           value="@_mvIn" @oninput="@(e => OnMoveInput(e, v => _mvIn = v))" />
                </div>
                <div class="cam-debug-row">
                    <label>Stride ease-out <span>@_mvOut.ToString("0.000")</span></label>
                    <input type="range" min="0.001" max="0.05" step="0.001"
                           value="@_mvOut" @oninput="@(e => OnMoveInput(e, v => _mvOut = v))" />
                </div>
                <div class="cam-debug-row">
                    <label>Run stride <span>@_mvStride.ToString("0.00")</span></label>
                    <input type="range" min="0" max="1" step="0.05"
                           value="@_mvStride" @oninput="@(e => OnMoveInput(e, v => _mvStride = v))" />
                </div>
                <div class="cam-debug-row">
                    <label>Step cap Hz <span>@(_mvStepHz == 0 ? "off" : _mvStepHz.ToString("0.0"))</span></label>
                    <input type="range" min="0" max="8" step="0.1"
                           value="@_mvStepHz" @oninput="@(e => OnMoveInput(e, v => _mvStepHz = v))" />
                </div>
                <div class="cam-debug-row">
                    <label><input type="checkbox" checked="@_mvInstantGait"
                                  @onchange="@(e => OnMoveCheck(e, v => _mvInstantGait = v))" /> Instant gait</label>
                    <label><input type="checkbox" checked="@_mvHardStop"
                                  @onchange="@(e => OnMoveCheck(e, v => _mvHardStop = v))" /> Hard stop</label>
                </div>
                <button class="cam-debug-reset" @onclick="ResetMovementDebug">Reset</button>
            </div>
        }
        @if (_camPanelOpen)
        {
            <div class="cam-debug-panel">
                <div class="cam-debug-row">
                    <label>FOV <span>@_camFov.ToString("0")</span></label>
                    <input type="range" min="10" max="90" step="1"
                           value="@_camFov" @oninput="OnCamFovInput" />
                </div>
                <div class="cam-debug-row">
                    <label>Depth squash <span>@_camTilt.ToString("0.00")</span></label>
                    <input type="range" min="0" max="1" step="0.01"
                           value="@_camTilt" @oninput="OnCamTiltInput" />
                </div>
                <div class="cam-debug-row">
                    <label>Pitch <span>@_camPitch.ToString("0.00")</span></label>
                    <input type="range" min="0.1" max="2.2" step="0.01"
                           value="@_camPitch" @oninput="OnCamPitchInput" />
                </div>
                <div class="cam-debug-row">
                    <label>Zoom <span>@_camZoom.ToString("0.00")</span></label>
                    <input type="range" min="0.2" max="4" step="0.01"
                           value="@_camZoom" @oninput="OnCamZoomInput" />
                </div>
                <button class="cam-debug-reset" @onclick="ResetCameraDebug">Reset</button>
            </div>
        }
    }
</div>

@code {
    [Parameter] public GameState? State { get; set; }
    [Parameter] public IReadOnlyList<CombatLogEntry> LogEntries { get; set; } = [];
    [Parameter] public bool EnemyDead { get; set; }
    [Parameter] public bool PlayerDead { get; set; }
    [Parameter] public string? WeaponId { get; set; }

    private int _lastCount;
    private bool _inited;
    private DotNetObjectReference<BattleScene>? _selfRef;
    private bool _lastTelegraph;
    private bool _lastPunished;
    private bool? _lastHoldPosition;
    private string? _lastWeapon;
    private string? _lastEquipment;
    private bool _deathFired;
    private string? _enemyId;
    private string _enemyName = "";
    private int _enemyMaxHp = 1;
    private bool EnemyFrozen => State?.EnemyFrozen ?? false;

    // Dev-only per-mechanic kill switches (M1 playtest tooling): each checkbox
    // dispatches a ToggleMechanicCommand, reflecting live GameState toggle flags.
    private bool _mechPanelOpen;
    private static readonly (string Label, BossMechanic Mech)[] MechToggles =
    [
        ("Boss autos", BossMechanic.BossAutos),
        ("Eruptions", BossMechanic.Eruptions),
        ("Pools", BossMechanic.Pools),
        ("Swarms", BossMechanic.Swarms),
        ("Rot Burst", BossMechanic.RotBurst),
        ("DoTs", BossMechanic.Dots),
    ];
    private async Task ToggleMechanic(BossMechanic mech)
    {
        if (GameSvc.PlayerId is { } pid)
            await GameSvc.DispatchAsync(new ToggleMechanicCommand(pid, mech));
        StateHasChanged();
    }

    // Admin camera debug panel (test fights only) — mirrors the JS defaults
    // in voxel.js (CAM_FOV, TILT, POS_TILT, camZoom=1) so the sliders start
    // in sync with what's already on screen.
    private bool _camPanelOpen;
    private double _camFov = 25;
    private double _camTilt = 0.3;
    private double _camPitch = 0.7;
    private double _camZoom = 1.0;

    // Movement-feel debug panel (test fights only). Unlike CAM, values are
    // SEEDED from voxel.getMovementDebug on open: tuning persists in
    // localStorage across reloads, so the panel must read, not assume.
    private bool _movePanelOpen;
    private double _mvSpeed = 1.0;
    private double _mvTurn = 0.03;
    private double _mvIn = 0.006;
    private double _mvOut = 0.01;
    private double _mvStride = 0.6;
    private double _mvStepHz = 4.3;
    private bool _mvInstantGait;
    private bool _mvHardStop;

    private sealed record MoveTune(double SpeedMult, double TurnRate, double StrideIn,
                                   double StrideOut, double RunStride, double MaxStepHz,
                                   bool InstantGait, bool HardStop);

    private async Task ToggleMovePanel()
    {
        _movePanelOpen = !_movePanelOpen;
        if (_movePanelOpen)
        {
            var t = await JS.InvokeAsync<MoveTune>("voxel.getMovementDebug");
            _mvSpeed = t.SpeedMult; _mvTurn = t.TurnRate;
            _mvIn = t.StrideIn; _mvOut = t.StrideOut; _mvStride = t.RunStride;
            _mvStepHz = t.MaxStepHz;
            _mvInstantGait = t.InstantGait; _mvHardStop = t.HardStop;
        }
        StateHasChanged();
    }

    private Task OnMoveInput(ChangeEventArgs e, Action<double> assign)
    {
        if (double.TryParse(e.Value?.ToString(), out var v)) assign(v);
        return PushMovementDebug();
    }

    private Task OnMoveCheck(ChangeEventArgs e, Action<bool> assign)
    {
        if (e.Value is bool b) assign(b);
        return PushMovementDebug();
    }

    private Task PushMovementDebug() =>
        JS.InvokeVoidAsync("voxel.setMovementDebug", "battle-canvas", new
        {
            speedMult = _mvSpeed, turnRate = _mvTurn,
            strideIn = _mvIn, strideOut = _mvOut, runStride = _mvStride,
            maxStepHz = _mvStepHz,
            instantGait = _mvInstantGait, hardStop = _mvHardStop,
        }).AsTask();

    private Task ResetMovementDebug()
    {
        _mvSpeed = 1.0; _mvTurn = 0.03; _mvIn = 0.006; _mvOut = 0.01;
        _mvStride = 0.6; _mvStepHz = 4.3; _mvInstantGait = false; _mvHardStop = false;
        return PushMovementDebug();
    }

    private string? _lastOverheads;

    protected override void OnParametersSet()
    {
        // Cache enemy identity so the death frame still renders after
        // EndDuel() nulls ActiveNpc.
        if (State?.ActiveNpc is { } npc)
        {
            _enemyId = npc.Template.Id;
            _enemyName = npc.Template.Name;
            _enemyMaxHp = npc.MaxHp;
        }
    }

    private int EnemyHp => EnemyDead ? 0 : State?.ActiveNpc?.CurrentHp ?? 0;
    private int EnemyHpPct => _enemyMaxHp > 0 ? EnemyHp * 100 / _enemyMaxHp : 0;

    private int PlayerHpPct =>
        State?.Player is { } p && p.MaxHp > 0 ? (int)(p.CurrentHp * 100.0 / p.MaxHp) : 0;

    // PrayerPoints caps at 99, not 100 — normalize for the bar fill.
    private int PlayerPrayerPct => (int)((State?.Player?.PrayerPoints ?? 0) * 100.0 / 99);

    // Non-telegraph boss-script warnings (Rot Burst, swarms, phase shift,
    // eruption waves) still surface as a text bubble — the style-shift
    // telegraph itself moved to the in-world StyleTelegraphSystem (rim glow +
    // windup pose + projectile) per the boss bible's "weapon glow / stance"
    // grammar, so its own log line is excluded here to avoid a redundant
    // pop-up duplicating what's now shown on the boss itself.
    private string? BubbleText =>
        State?.CombatLog.LastOrDefault(e =>
            e.Kind == LogEntryKind.BossSpecial &&
            !e.Message.Contains("mandibles glow") &&
            (DateTimeOffset.UtcNow - e.Timestamp) < TimeSpan.FromSeconds(2.4))?.Message;

    // Forecast widget (UI bible §3.2): "a HUD echo of the in-world tell" —
    // secondary to the StyleTelegraphSystem below. Resolved to a badge only
    // for a single (non-compound) attack; the compound "lash/grub_volley"
    // read genuinely has no single style to show an icon for yet.
    private AttackType? ForecastStyle
    {
        get
        {
            var npc = State?.ActiveNpc;
            if (npc?.ForecastAttackId is not { } id || id.Contains('/')) return null;
            return npc.Template.Script?.Attacks.GetValueOrDefault(id)?.Style;
        }
    }

    // StyleTelegraphSystem (shared, boss-agnostic): the primary in-world
    // tell per the boss bible's prayer grammar ("weapon glow / stance") and
    // UI bible §1's doctrine colors. Compound telegraphs (style undecided
    // until cast time, per the King's "his choice depends on YOUR position")
    // used to reuse "ranged" green for this glow, on the theory that it was
    // the Boss Bible's own literal color for the transition — but every
    // OTHER green thing in this game (prayer strip, overhead icon,
    // projectiles) means "ranged, specifically," so it read as a promise
    // the boss wasn't making and got misprayed on (M1 playtest report).
    // "ambiguous" is a genuinely neutral amber, not a 4th doctrine color —
    // matches the ForecastMessage text ("mandibles glow amber"), which
    // already disagreed with the old glow color. A resolved single style
    // (Bile Spit's Magic, or the King's return-to-Magic telegraph) still
    // uses its own doctrine color; projectile visuals still only fire for a
    // style we're actually committing to, never the ambiguous case.
    private (string? Style, bool Projectile) TelegraphVisual
    {
        get
        {
            var npc = State?.ActiveNpc;
            if (npc?.ForecastAttackId is not { } id) return (null, false);
            if (id.Contains('/')) return ("ambiguous", false);
            var style = npc.Template.Script?.Attacks.GetValueOrDefault(id)?.Style;
            if (style is null) return (null, false);
            var cls = StyleClass(style.Value);
            return (cls, cls is "ranged" or "magic");
        }
    }

    // Overhead prayer icons: a billboarded icon-in-a-ring above the actor's
    // head, rendered in-world by toon.js's shared overhead renderer (M1
    // playtest revision — see setActorOverhead). These just name the active
    // style key per side; NpcOverhead stays null until bosses grant one.
    private string? PlayerOverhead => State?.Player switch
    {
        { ActiveProtection: ProtectionPrayer.Melee } => "melee",
        { ActiveProtection: ProtectionPrayer.Range } => "ranged",
        { ActiveProtection: ProtectionPrayer.Magic } => "magic",
        { BoostPrayerActive: true }                  => "piety",
        _ => null,
    };

    private string? NpcOverhead => null;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Seed the log cursor first: entries that existed before the scene
            // mounted must not fire splats/animations.
            _lastCount = LogEntries.Count;
            _selfRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("voxel.initBattle", "battle-canvas", new
            {
                playerUrl = "assets/player_sakuna.vox",
                playerRigId = "player_sakuna",
                enemyId = _enemyId,
                scene = State?.TestScene == true ? "field" : "arena",
                dotnetRef = _selfRef,
            });
            _lastWeapon = WeaponId;
            await JS.InvokeVoidAsync("voxel.setBattleWeapon", "battle-canvas", WeaponId);
            _lastEquipment = EquipmentKey();
            await JS.InvokeVoidAsync("voxel.setBattleEquipment", "battle-canvas", EquippedGearIds());
            // Solid obstacles the movers pathfind around — placed as low props the
            // scene renders on those tiles. Fixed per duel, so send once on mount.
            await JS.InvokeVoidAsync("voxel.setBattleObstacles", "battle-canvas",
                State?.Obstacles.Select(o => new { x = o.X, z = o.Z }).ToArray() ?? []);
            // Landscape fight auto-rotates in portrait; keep canvas taps mapped.
            await JS.InvokeVoidAsync("voxel.watchOrientation", "battle-canvas");
            _inited = true;
            return;
        }
        if (!_inited) return;

        // RETRY rematches reuse the mounted scene — restore the crumbled loser.
        if (State?.InDuel == true && _deathFired)
        {
            _deathFired = false;
            await JS.InvokeVoidAsync("voxel.resetBattle", "battle-canvas");
        }

        // A retry/re-fight can swap the enemy without remounting the scene.
        if (State?.ActiveNpc is { } npc && npc.Template.Id != _enemyId)
        {
            _enemyId = npc.Template.Id;
            await JS.InvokeVoidAsync("voxel.setBattleEnemy", "battle-canvas", _enemyId);
        }

        // Weapon switches show up in the player's hand.
        if (WeaponId != _lastWeapon)
        {
            _lastWeapon = WeaponId;
            await JS.InvokeVoidAsync("voxel.setBattleWeapon", "battle-canvas", WeaponId);
        }

        // Armor changes show up on the player's body (modeled pieces only).
        if (EquipmentKey() is var equipKey && equipKey != _lastEquipment)
        {
            _lastEquipment = equipKey;
            await JS.InvokeVoidAsync("voxel.setBattleEquipment", "battle-canvas", EquippedGearIds());
        }

        // Log diff computed up front (not after the position send below) so
        // this tick's teleport marker, if any, is known before building the
        // position snapshot — the renderer's interpolation layer needs to
        // know NOW whether to snap or lerp, not on the next diff.
        var newEntries = LogEntries.Count > _lastCount ? LogEntries.Skip(_lastCount).ToList() : [];
        _lastCount = LogEntries.Count;
        bool playerTeleported = newEntries.Any(e => e.Kind == LogEntryKind.PlayerTeleport);
        bool npcTeleported = newEntries.Any(e => e.Kind == LogEntryKind.NpcTeleport);

        // HP fractions drive voxel erosion (damage chips the model, food regrows it).
        await JS.InvokeVoidAsync("voxel.setBattleVitals", "battle-canvas", new
        {
            player = State?.Player is { MaxHp: > 0 } pl ? pl.CurrentHp / (double)pl.MaxHp : 1.0,
            enemy = _enemyMaxHp > 0 ? EnemyHp / (double)_enemyMaxHp : 1.0,
        });

        // Sim tile positions — the scene walks the actors toward these.
        // Renderer interpolation layer: `discontinuous` tells toon.js whether
        // this tick's move should snap (dash/teleport/knockback) or lerp
        // (an ordinary step) — see the PlayerTeleport/NpcTeleport log kinds.
        // Adds are always continuous in M1 (they only ever crawl); enemy is
        // always continuous too (Maggot King is stationary) but wired
        // symmetrically for whenever a future boss dashes.
        if (State is { } s)
        {
            await JS.InvokeVoidAsync("voxel.setBattlePositions", "battle-canvas", new
            {
                player = new { x = s.PlayerTile.X, z = s.PlayerTile.Z, discontinuous = playerTeleported },
                enemy = new { x = s.NpcTile.X, z = s.NpcTile.Z, discontinuous = npcTeleported },
            });
            // Tile hazards v2 (boss mechanic): warning fuse -> pool -> scorch
            // (permanent, safe). JS diffs pending→gone itself to fire the
            // eruption burst, so no separate event plumbing is needed.
            await JS.InvokeVoidAsync("voxel.setBattleHazards", "battle-canvas", new
            {
                pending = s.Hazards.Where(h => h.State == HazardState.Warning).Select(h => new { x = h.X, z = h.Z, t = h.TicksLeft }).ToArray(),
                pools   = s.Hazards.Where(h => h.State == HazardState.Pool).Select(h => new { x = h.X, z = h.Z }).ToArray(),
                scorch  = s.Hazards.Where(h => h.State == HazardState.Scorch).Select(h => new { x = h.X, z = h.Z }).ToArray(),
            });
            // Swarm adds (m1-plan Workstream C.7).
            await JS.InvokeVoidAsync("voxel.setBattleAdds", "battle-canvas",
                s.Adds.Select(a => new { id = a.Id, x = a.Tile.X, z = a.Tile.Z, hpPct = a.MaxHp > 0 ? a.CurrentHp * 100 / a.MaxHp : 0, discontinuous = false }).ToArray());
        }

        // Overhead prayer icons (billboarded in-world sprite); send only on change.
        var overheads = $"{PlayerOverhead}|{NpcOverhead}";
        if (overheads != _lastOverheads)
        {
            _lastOverheads = overheads;
            await JS.InvokeVoidAsync("voxel.setBattleOverheads", "battle-canvas",
                new { player = PlayerOverhead, enemy = NpcOverhead });
        }

        foreach (var e in newEntries)
        {
            // Flask sip: raise-to-mouth animation (UI bible §3.2 flask belt).
            if (e.Kind == LogEntryKind.Info && e.Message.StartsWith("You sip the "))
            {
                var rest = e.Message["You sip the ".Length..];
                var dot = rest.IndexOf('.');
                var item = dot > 0 ? rest[..dot] : rest;
                await JS.InvokeVoidAsync("voxel.battleEvent", "battle-canvas",
                    new { type = "playerSip", item });
                continue;
            }
            if (e.Kind == LogEntryKind.System && e.Message.StartsWith("✦ PERFECT DODGE"))
            {
                await JS.InvokeVoidAsync("voxel.battleEvent", "battle-canvas", new { type = "perfectDodge" });
                continue;
            }
            // Impact-resolution prayer (Global Combat Grammar): a ranged/magic
            // attack's cast tick fires this — the windup animation AND the
            // doctrine-colored projectile launch — well before its hitsplat
            // shows up (that lands ProjectileFlightTicks ticks later, at
            // impact). Reuses the same 'enemyAttack' JS handler a melee hit
            // uses for its (instant, same-tick) swing; toon.js tells them
            // apart by style, spawning a projectile only for ranged/magic.
            if (e.Kind == LogEntryKind.BossCast)
            {
                var castParts = e.Message.Split(':');
                await JS.InvokeVoidAsync("voxel.battleEvent", "battle-canvas",
                    new
                    {
                        type = "enemyAttack",
                        style = castParts[0],
                        tier = "normal",
                        weapon = (string?)null,
                        ticks = castParts.Length > 1 && int.TryParse(castParts[1], out var ct) ? ct : 2,
                    });
                continue;
            }
            if (e.Kind is not (LogEntryKind.HitsplatPlayer or LogEntryKind.HitsplatNpc)) continue;
            var parts = e.Message.Split(':');
            int dmg = int.TryParse(parts[0], out var d) ? d : 0;
            string tier = parts.Length > 1 ? parts[1] : "normal";

            // HitsplatPlayer = damage dealt BY the player → lands on the enemy;
            // HitsplatNpc = damage dealt BY the NPC → lands on the player.
            // (The splat itself is drawn in-canvas by battleEvent's impact.)
            bool onEnemy = e.Kind == LogEntryKind.HitsplatPlayer;

            // parts[2]'s meaning depends on who's hitting: a player spec
            // hitsplat carries the weapon it was thrown with (e.g. a dds spec
            // that reverts to the main-hand this same tick — show that weapon
            // + its animation, not the reverted equipped weapon); a boss
            // hitsplat instead carries its real attack style (melee/ranged/
            // magic), so its impact animation matches what actually hit
            // rather than always defaulting to a melee swing.
            string? specWeapon = onEnemy && parts.Length > 2 && parts[2].Length > 0 ? parts[2] : null;
            string? npcStyle = !onEnemy && parts.Length > 2 && parts[2].Length > 0 ? parts[2] : null;

            // A ranged/magic NPC hitsplat is this attack's IMPACT — its swing
            // + projectile already played back at the earlier BossCast event
            // (ProjectileFlightTicks ticks ago), so re-firing 'enemyAttack'
            // here would double the animation and spawn a second projectile
            // right on top of the first one landing. Melee never has a cast
            // phase (impact tick == cast tick), so it still fires here as
            // its only trigger, unchanged.
            bool alreadyAnimatedAtCast = !onEnemy && npcStyle is "ranged" or "magic";

            // DoT ticks and ground hazards aren't attacks — no swing, just
            // the victim's flash (the eruption burst is drawn tile-side).
            if (tier is not ("poison" or "hazard") && !alreadyAnimatedAtCast)
                await JS.InvokeVoidAsync("voxel.battleEvent", "battle-canvas",
                    new
                    {
                        type = onEnemy ? "playerAttack" : "enemyAttack",
                        style = onEnemy ? PlayerStyle() : npcStyle,
                        kind = onEnemy ? PlayerKind() : null,
                        tier,   // 'spec' selects the weapon's special-attack flourish
                        weapon = onEnemy ? (specWeapon ?? WeaponId) : null, // spec weapon wins the revert race
                    });
            // style rides along so a "blocked" splat (a prayer-negated hit)
            // can render in the doctrine color that blocked it — confirms
            // which prayer worked, not just that something was prevented.
            await JS.InvokeVoidAsync("voxel.battleEvent", "battle-canvas",
                new { type = onEnemy ? "enemyHit" : "playerHit", tier, dmg, style = onEnemy ? PlayerStyle() : npcStyle });
        }

        if (newEntries.Any(e => e.Kind is LogEntryKind.MaxHit or LogEntryKind.SpecHit or LogEntryKind.BossSpecial))
            await JS.InvokeVoidAsync("triggerShake", "battle-scene", 180);

        // StyleTelegraphSystem: rim glow + windup pose (+ projectile for a
        // committed ranged/magic read), fired on the rising edge only — the
        // renderer owns the pose/projectile lifecycle from there.
        var (telegraphStyle, telegraphProjectile) = TelegraphVisual;
        bool telegraphActive = telegraphStyle is not null && !EnemyDead && !PlayerDead;
        if (telegraphActive != _lastTelegraph)
        {
            _lastTelegraph = telegraphActive;
            await JS.InvokeVoidAsync("voxel.setBattleTelegraph", "battle-canvas",
                new { active = telegraphActive, style = telegraphStyle, projectile = telegraphProjectile, ticks = 2 });
        }

        // Punish window (m1-plan Workstream C.6): boss can't act, +25% damage
        // taken — the pulsing ring cue under it.
        bool punished = State is { ActiveNpc.InPunishWindow: true } && !EnemyDead && !PlayerDead;
        if (punished != _lastPunished)
        {
            _lastPunished = punished;
            await JS.InvokeVoidAsync("voxel.setBattleFlags", "battle-canvas", new { punished });
        }

        bool holdPosition = State?.HoldPosition ?? false;
        if (holdPosition != _lastHoldPosition)
        {
            _lastHoldPosition = holdPosition;
            await JS.InvokeVoidAsync("voxel.setBattleFlags", "battle-canvas", new { holdPosition });
        }

        if ((EnemyDead || PlayerDead) && !_deathFired)
        {
            _deathFired = true;
            await JS.InvokeVoidAsync("voxel.battleEvent", "battle-canvas",
                new { type = EnemyDead ? "enemyDeath" : "playerDeath" });
        }
    }

    // Scene taps, forwarded from voxel.js: a ground tap orders a walk
    // (disengaging), an enemy tap re-engages the chase.
    private async Task ToggleFreezeEnemy()
    {
        if (GameSvc.PlayerId is { } pid)
            await GameSvc.DispatchAsync(new FreezeEnemyCommand(pid, !EnemyFrozen));
    }

    // Camera debug panel: each slider pushes the full set of four values —
    // voxel.setCameraDebug is idempotent and cheap, so no point diffing.
    private Task OnCamFovInput(ChangeEventArgs e) => SetCamField(e, v => _camFov = v);
    private Task OnCamTiltInput(ChangeEventArgs e) => SetCamField(e, v => _camTilt = v);
    private Task OnCamPitchInput(ChangeEventArgs e) => SetCamField(e, v => _camPitch = v);
    private Task OnCamZoomInput(ChangeEventArgs e) => SetCamField(e, v => _camZoom = v);

    private Task SetCamField(ChangeEventArgs e, Action<double> assign)
    {
        if (double.TryParse(e.Value?.ToString(), out var v)) assign(v);
        return PushCameraDebug();
    }

    private Task PushCameraDebug() =>
        JS.InvokeVoidAsync("voxel.setCameraDebug", "battle-canvas",
            new { fov = _camFov, tilt = _camTilt, pitch = _camPitch, zoom = _camZoom }).AsTask();

    private Task ResetCameraDebug()
    {
        _camFov = 25; _camTilt = 0.3; _camPitch = 0.7; _camZoom = 1.0;
        return PushCameraDebug();
    }

    [JSInvokable]
    public async Task OnGroundClick(int x, int z)
    {
        if (GameSvc.PlayerId is { } pid)
        {
            await GameSvc.DispatchAsync(new MoveToCommand(pid, x, z));
            await TickService.KickMoveAsync(pid); // step on the click, not next tick
        }
    }

    [JSInvokable]
    public async Task OnEnemyClick()
    {
        if (GameSvc.PlayerId is { } pid)
        {
            await GameSvc.DispatchAsync(new SetTargetCommand(pid, null));
            await GameSvc.DispatchAsync(new EngageCommand(pid));
        }
    }

    // Tap a swarm add to target it (m1-plan Workstream C.7).
    [JSInvokable]
    public async Task OnAddClick(string addId)
    {
        if (GameSvc.PlayerId is { } pid)
            await GameSvc.DispatchAsync(new SetTargetCommand(pid, addId));
    }

    // Non-weapon equipped item ids, sorted for a stable diff key — the scene
    // renders the ones with modeled assets as outfit pieces on the character.
    private string[] EquippedGearIds() =>
        State?.Player?.Equipped
            .Where(kv => kv.Key != EquipmentSlot.Weapon)
            .Select(kv => kv.Value)
            .OrderBy(id => id, StringComparer.Ordinal)
            .ToArray() ?? [];

    private string EquipmentKey() => string.Join(",", EquippedGearIds());

    // The player's projectile/effect style comes from the equipped weapon.
    private string PlayerStyle() =>
        WeaponId is { } id && ItemRepo.GetWeapon(id) is { } w ? StyleClass(w.AttackType) : "melee";

    // Swing choreography kind: the weapon's AttackType (stab/slash/crush);
    // bare fists punch like a crush. voxel.js applies per-weapon overrides.
    private string PlayerKind() =>
        WeaponId is { } id && ItemRepo.GetWeapon(id) is { } w
            ? w.AttackType.ToString().ToLowerInvariant() : "crush";

    private static string StyleClass(AttackType t) => t switch
    {
        AttackType.Ranged => "ranged",
        AttackType.Magic  => "magic",
        _                 => "melee",
    };

    private static string StyleIcon(AttackType t) => t switch
    {
        AttackType.Ranged => "➶",
        AttackType.Magic  => "✦",
        _                 => "⚔",
    };

    private static string StyleName(AttackType t) => t switch
    {
        AttackType.Ranged => "Ranged — pray ⛉R",
        AttackType.Magic  => "Magic — pray ⛉MG",
        _                 => "Melee — pray ⛉M",
    };

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("voxel.destroyBattle", "battle-canvas"); }
        catch { /* JS runtime tearing down */ }
        _selfRef?.Dispose();
    }
}
