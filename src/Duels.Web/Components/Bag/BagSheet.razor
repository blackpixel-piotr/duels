@using Duels.Application.GameSession
@using Duels.Application.Commands
@using Duels.Application.Abstractions
@using Duels.Domain.ValueObjects
@using Duels.Web.Components.Equipment
@inject Duels.Web.Services.GameService GameSvc
@inject IItemRepository ItemRepo

<div class="shop-overlay" @onclick="OnClose">
    <div class="shop-panel bag-panel" @onclick:stopPropagation>
        <div class="shop-header">
            <span class="shop-title">Bag</span>
            <span class="shop-gold">@(State?.Player?.Gold.ToString("N0") ?? "0") gp</span>
            <button class="shop-close" @onclick="OnClose" title="Close">✕</button>
        </div>
        @* Landscape-everywhere mandate (backlog resolution batch 1 §10): gear
           + preview + stats sit in a left column beside the inventory grid,
           not stacked above it in one tall scrolling column. *@
        <div class="bag-body">
            <div class="bag-left-col">
                <div class="paperdoll">
                    <div class="paperdoll-col">
                        @foreach (var slot in _leftSlots)
                        {
                            <EquipmentSlotButton Slot="@slot" ItemId="@Item(slot)" />
                        }
                    </div>
                    <PlayerPreview EquippedItemIds="@(State?.Player?.Equipped.Values.ToList() ?? [])" />
                    <div class="paperdoll-col">
                        @foreach (var slot in _rightSlots)
                        {
                            <EquipmentSlotButton Slot="@slot" ItemId="@Item(slot)" />
                        }
                    </div>
                </div>

                <EquipmentStatSheet State="@State" />

                @if (_compareItemId is { } compareId)
                {
                    <CompareCard ItemId="@compareId"
                                 EquippedItemId="@EquippedInSameSlot(compareId)"
                                 OnEquip="@(() => Equip(compareId))"
                                 OnCancel="@(() => _compareItemId = null)" />
                }
            </div>

            <InventoryGrid State="@State" OnSelectItem="@(id => _compareItemId = id)" />
        </div>
    </div>
</div>

@code {
    [Parameter] public GameState? State { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    // RS3-style split: armour on the left, hands/feet/jewellery on the right.
    private static readonly EquipmentSlot[] _leftSlots =
        [EquipmentSlot.Helmet, EquipmentSlot.Cape, EquipmentSlot.Amulet, EquipmentSlot.Body, EquipmentSlot.Legs];
    private static readonly EquipmentSlot[] _rightSlots =
        [EquipmentSlot.Weapon, EquipmentSlot.Shield, EquipmentSlot.Gloves, EquipmentSlot.Boots, EquipmentSlot.Ring];

    private string? _compareItemId;

    private string? Item(EquipmentSlot slot) => State?.Player?.Equipped.GetValueOrDefault(slot);

    private string? EquippedInSameSlot(string candidateItemId)
    {
        var slot = ItemRepo.GetGear(candidateItemId)?.Slot;
        return slot is null ? null : Item(slot.Value);
    }

    private async Task Equip(string itemId)
    {
        _compareItemId = null;
        if (GameSvc.PlayerId is null) return;
        await GameSvc.DispatchAsync(new EquipItemCommand(GameSvc.PlayerId!, itemId));
    }
}
