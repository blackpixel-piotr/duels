@using Duels.Application.GameSession
@using Duels.Domain.ValueObjects
@using Duels.Web.Components.Equipment

<div class="shop-overlay" @onclick="OnClose">
    <div class="shop-panel bag-panel" @onclick:stopPropagation>
        <div class="shop-header">
            <span class="shop-title">Bag</span>
            <span class="shop-gold">@(State?.Player?.Gold.ToString("N0") ?? "0") gp</span>
            <button class="shop-close" @onclick="OnClose" title="Close">✕</button>
        </div>
        <div class="bag-body">
            <div class="paperdoll">
                <div class="paperdoll-col">
                    @foreach (var slot in _leftSlots)
                    {
                        <EquipmentSlotButton Slot="@slot" ItemId="@Item(slot)" />
                    }
                </div>
                <PlayerPreview />
                <div class="paperdoll-col">
                    @foreach (var slot in _rightSlots)
                    {
                        <EquipmentSlotButton Slot="@slot" ItemId="@Item(slot)" />
                    }
                </div>
            </div>
            <InventoryGrid State="@State" />
        </div>
    </div>
</div>

@code {
    [Parameter] public GameState? State { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    // RS3-style split: armour on the left, hands/feet/jewellery on the right.
    private static readonly EquipmentSlot[] _leftSlots =
        [EquipmentSlot.Helmet, EquipmentSlot.Cape, EquipmentSlot.Amulet, EquipmentSlot.Body, EquipmentSlot.Legs];
    private static readonly EquipmentSlot[] _rightSlots =
        [EquipmentSlot.Weapon, EquipmentSlot.Shield, EquipmentSlot.Gloves, EquipmentSlot.Boots, EquipmentSlot.Ring];

    private string? Item(EquipmentSlot slot) => State?.Player?.Equipped.GetValueOrDefault(slot);
}
