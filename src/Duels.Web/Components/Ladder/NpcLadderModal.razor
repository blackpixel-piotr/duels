@using Duels.Application.GameSession
@using Duels.Application.Commands
@using Duels.Application.Abstractions
@using Duels.Domain.Entities
@inject Duels.Web.Services.GameService GameSvc
@inject IItemRepository ItemRepo
@inject INpcRepository NpcRepo

<div class="ladder-overlay" @onclick="OnClose">
    <div class="ladder-panel" @onclick:stopPropagation>

        <div class="ladder-header">
            <span class="ladder-title">Duel Arena</span>
            <span class="ladder-gold">@(State?.Player?.Gold.ToString("N0") ?? "0") gp</span>
            <button class="shop-close" @onclick="OnClose" title="Close">✕</button>
        </div>

        <div class="ladder-wager-row">
            <span class="ladder-wager-label">Set Active Stake</span>
            <input class="ladder-wager-input @(_wagerTooHigh ? "wager-invalid" : "")"
                   type="number" min="0"
                   value="@_wagerStr"
                   @oninput="OnWagerInput"
                   placeholder="0" />
            <button class="ladder-bet-btn" @onclick="() => AddWager(1_000)">+1k</button>
            <button class="ladder-bet-btn" @onclick="() => AddWager(10_000)">+10k</button>
            <button class="ladder-bet-btn" @onclick="() => AddWager(100_000)">+100k</button>
            <button class="ladder-bet-btn ladder-bet-max" @onclick="() => SetWager(MaxGold)">Max</button>
        </div>

        <div class="ladder-endless" @onclick="FightEndless">
            <span class="ladder-endless-icon">♾</span>
            <div class="ladder-endless-body">
                <span class="ladder-endless-title">ENDLESS MODE</span>
                <span class="ladder-endless-sub">@(BestWave > 0 ? $"Best: Wave {BestWave}" : "Fight until you fall")</span>
            </div>
        </div>

        <div class="ladder-grid">
            @foreach (var stageId in _order)
            {
                var template = NpcRepo.GetTemplate(stageId);
                if (template is null) continue;
                var npcLocal = template;
                bool unlocked = State?.UnlockedOpponents.Contains(stageId) ?? false;
                bool obtained = State?.Player?.HasItem(SignatureDropId(template) ?? "") ?? false;
                <div class="ladder-card @(unlocked ? "ladder-unlocked" : "ladder-locked")">
                    <div class="ladder-stage">@StageLabel(stageId)</div>
                    @if (unlocked)
                    {
                        <div class="ladder-npc-name">@template.Name</div>
                        <div class="ladder-stats">
                            <span>Lvl @template.CombatLevel</span>
                            <span>HP @template.Stats.Hitpoints</span>
                        </div>
                        @if (template.GoldReward > 0)
                        {
                            <div class="ladder-bounty">💰 @template.GoldReward.ToString("N0")g bounty</div>
                        }
                        @if (SignatureDropId(template) is { } dropId)
                        {
                            <div class="ladder-drop @(obtained ? "ladder-drop-obtained" : "")">
                                @(obtained ? "✓ " : "🎲 ")@(ItemRepo.GetItemName(dropId) ?? dropId)
                            </div>
                        }
                        <div class="ladder-reward">Max: @template.MaxWager.ToString("N0")g</div>
                        <button class="ladder-fight-btn" @onclick="() => Fight(npcLocal)">⚔ Fight</button>
                    }
                    else
                    {
                        <div class="ladder-lock-icon">🔒</div>
                        <div class="ladder-locked-text">LOCKED</div>
                    }
                </div>
            }
        </div>

    </div>
</div>

@code {
    [Parameter] public GameState? State { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnDuelStarted { get; set; }

    private int    _wager        = 0;
    private string _wagerStr     = "0";
    private bool   _wagerTooHigh = false;

    private int MaxGold => State?.Player?.Gold ?? 0;
    private int BestWave => State?.BestEndlessWave ?? 0;

    private static readonly string[] _order =
    [
        "goblin", "swashbuckler", "barbarian", "desert_bandit", "gladiator",
        "corsair", "berserker", "warlord", "champion",
    ];

    private static string StageLabel(string id) => id == "goblin" ? "Starter" : $"Stage {Array.IndexOf(_order, id)}";

    private static string? SignatureDropId(NpcTemplate template) =>
        template.LootTable.FirstOrDefault(e => e.OnceOnly && e.ItemId != "corrupted_whip")?.ItemId;

    private void SetWager(int value)
    {
        _wager        = Math.Clamp(value, 0, MaxGold);
        _wagerStr     = _wager.ToString();
        _wagerTooHigh = false;
    }

    private void AddWager(int amount) => SetWager(_wager + amount);

    private void OnWagerInput(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int v) && v >= 0)
        {
            _wagerTooHigh = v > MaxGold;
            _wager        = Math.Min(v, MaxGold);
            _wagerStr     = v.ToString();
        }
        else
        {
            _wager        = 0;
            _wagerStr     = "0";
            _wagerTooHigh = false;
        }
    }

    private async Task Fight(NpcTemplate npc)
    {
        if (GameSvc.PlayerId is null) return;
        await GameSvc.DispatchAsync(new StartDuelCommand(GameSvc.PlayerId!, npc.Id, _wager > 0 ? _wager : 0));
        await OnDuelStarted.InvokeAsync();
    }

    private async Task FightEndless()
    {
        if (GameSvc.PlayerId is null) return;
        await GameSvc.DispatchAsync(new StartEndlessCommand(GameSvc.PlayerId!));
        await OnDuelStarted.InvokeAsync();
    }
}
