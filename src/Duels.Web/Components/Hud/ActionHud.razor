@using Duels.Application.GameSession
@using Duels.Application.Abstractions
@using Duels.Application.Commands
@using Duels.Domain.ValueObjects
@using Duels.Domain.Entities
@inject Duels.Web.Services.GameService GameSvc
@inject IItemRepository ItemRepo

<div class="action-hud action-hud-@Layout">
    @if (State?.InDuel == true)
    {
        <div class="tick-metronome" id="tick-bar"></div>

        @* ── Flask belt (UI bible §3.2): 2 bound slots, sip pips, dims attack while consumed ── *@
        <div class="hud-row hud-belt">
            @for (int i = 0; i < 2; i++)
            {
                var slotIndex = i;
                var slot = State.Player!.FlaskBelt.Slots[slotIndex];
                <button class="belt-slot @(slot.FlaskId is null ? "belt-empty" : "") @(slot.SipsRemaining == 0 && slot.FlaskId is not null ? "qs-spec-depleted" : "")"
                        title="@FlaskTitle(slot)"
                        disabled="@(_busy || slot.FlaskId is null || slot.SipsRemaining == 0)"
                        @onclick="() => Sip(slotIndex)">
                    <span class="belt-icon">@(slot.FlaskId == "flask_prayer" ? "🧪" : "❤")</span>
                    <span class="belt-pips">@SipPips(slot)</span>
                </button>
            }
        </div>

        @* ── Attack the current target: boss by default, or a tapped add. ── *@
        <div class="hud-row hud-target-row">
            <button class="attack-target-btn @(State.PlayerCooldown == 0 && !State.HoldPosition ? "qs-ready" : "") @QueuedClass(State.QueuedAction != null)"
                    title="Attack @TargetName" disabled="@_busy" @onclick="Attack">
                <span class="atk-target-icon">⚔</span>
                <span class="atk-target-text">
                    <span class="atk-target-label">ATTACK</span>
                    <span class="atk-target-name">@TargetName</span>
                </span>
            </button>
        </div>

        @* ── Weapon action bar (RS3-style, UI bible §4): sourced from the bound Loadout, not inventory ── *@
        <div class="hud-row hud-weapons">
            @{ var weaponSlots = WeaponSlots().ToList(); }
            @foreach (var slot in weaponSlots)
            {
                var slotLocal = slot;
                @if (slot.WeaponId is null)
                {
                    <button class="quickslot qs-empty" title="Empty slot — bind in the Loadout Editor" disabled>
                        <span class="qs-icon">—</span>
                    </button>
                }
                else
                {
                    <button @key="slot.WeaponId" class="quickslot @(slot.IsPrimary ? "qs-primary" : "") @(slot.IsPrimary && State.PlayerCooldown == 0 ? "qs-ready" : "") @(slot.SpecDepleted ? "qs-spec-depleted" : "") @QueuedClass(slot.IsQueued)"
                            title="@slot.Label"
                            disabled="@_busy"
                            @onclick="() => WeaponShortcut(slotLocal.WeaponId!)">
                        @if (slot.IsPrimary)
                        {
                            <span class="qs-cd-fill" style="height:@(CooldownPct(slot.WeaponId))%"></span>
                        }
                        @if (slot.SpecCost is { } cost)
                        {
                            <span class="qs-spec-badge">@cost%</span>
                        }
                        <VoxelIcon ItemId="@slot.WeaponId" Size="40">
                            <Fallback>
                                <span class="qs-icon">⚔</span>
                                <span class="qs-label">@slot.Label</span>
                            </Fallback>
                        </VoxelIcon>
                    </button>
                }
            }
            <button class="quickslot qs-special" title="Special attack" disabled="@_busy" @onclick="Spec">
                <span class="qs-spec-fill" style="height:@(State.Player!.SpecialEnergy)%"></span>
                <span class="qs-icon">⚡</span>
            </button>
        </div>

        @* ── Boost prayer + style (protection prayers moved to the left-edge
             PrayerStrip — UI bible §3.2, M1 playtest revision) ── *@
        <div class="hud-row hud-prayers">
            @{
                var boostActive = State.Player?.BoostPrayerActive == true;
                var noPrayer    = (State.Player?.PrayerPoints ?? 0) <= 0;
            }
            <button class="quickslot pray-slot @(boostActive ? "qs-active" : "") @(noPrayer ? "qs-spec-depleted" : "")"
                    title="Boost prayer — +20% damage, drains prayer" disabled="@_busy" @onclick="Boost">
                <span class="qs-icon">⚡</span><span class="qs-label">BOOST</span>
            </button>
            <button class="quickslot pray-slot" title="Cycle combat style" disabled="@_busy" @onclick="CycleStyle">
                <span class="qs-icon">🎯</span><span class="qs-label">@CurrentStyleLabel</span>
            </button>
        </div>
    }
    else
    {
        <div class="hud-row hud-nav">
            <button class="quickslot nav-slot" title="Bag — inventory & equipment" @onclick="() => OnOpenBag.InvokeAsync()">
                <span class="qs-icon">🎒</span><span class="qs-label">BAG</span>
            </button>
            <button class="quickslot nav-slot" title="Character sheet" @onclick="() => OnOpenCharacter.InvokeAsync()">
                <span class="qs-icon">📜</span><span class="qs-label">CHAR</span>
            </button>
        </div>
    }
</div>

@code {
    [Parameter] public GameState? State { get; set; }
    // "dock" = bottom grid in the portrait hub; "float" = RS3-style floating
    // clusters over the full-bleed fight (same buttons, positioned by CSS).
    [Parameter] public string Layout { get; set; } = "dock";
    [Parameter] public EventCallback OnOpenBag { get; set; }
    [Parameter] public EventCallback OnOpenCharacter { get; set; }

    private bool _busy;

    private static readonly Dictionary<string, int> _specCosts = new()
    {
        ["wpn_melee_t1"]  = 25, ["wpn_ranged_t1"] = 25, ["wpn_magic_t1"] = 25,
        ["wpn_melee_t2"]  = 40, ["wpn_ranged_t2"] = 40, ["wpn_magic_t2"] = 40,
    };

    private string TargetName => State?.CurrentTargetAdd is { } add
        ? "Maggot Swarm"
        : State?.ActiveNpc?.Template.Name ?? "—";

    private string FlaskTitle(FlaskSlotState slot) => slot.FlaskId switch
    {
        "flask_health" => "Health Flask — restores 40 HP",
        "flask_prayer" => "Prayer Flask — restores 40 prayer",
        _ => "Empty slot — bind in the Loadout Editor",
    };

    private static string SipPips(FlaskSlotState slot) =>
        slot.FlaskId is null ? "" : string.Concat(Enumerable.Range(0, slot.MaxSips).Select(i => i < slot.SipsRemaining ? "●" : "○"));

    private int CooldownPct(string? weaponId)
    {
        int cd = State?.PlayerCooldown ?? 0;
        if (cd <= 0) return 0;
        int speed = weaponId is not null ? (ItemRepo.GetWeapon(weaponId)?.AttackSpeed ?? 4) : 4;
        return Math.Clamp(cd * 100 / Math.Max(1, speed), 0, 100);
    }

    private string QueuedClass(bool isQueued) =>
        !isQueued ? ""
        : State?.QueuedAction == "spec" ? "qs-queued qs-queued-spec"
        : "qs-queued";

    private IEnumerable<WeaponSlotDef> WeaponSlots()
    {
        if (State?.Player is not { } player) yield break;
        var equippedId = player.GetEquippedWeaponId();
        var primaryId  = equippedId;

        for (int i = 0; i < 4; i++)
        {
            var boundId = player.Loadout.WeaponSlots.ElementAtOrDefault(i);
            bool isPrimary = boundId is not null && boundId == primaryId;
            bool isQueued  = isPrimary && State?.QueuedAction != null;
            bool depleted  = boundId is not null && _specCosts.TryGetValue(boundId, out int cost) && (State?.Player?.SpecialEnergy ?? 100) < cost;
            int? specCost  = boundId is not null && _specCosts.TryGetValue(boundId, out int c) ? c : null;
            yield return new WeaponSlotDef(boundId, Label(boundId), isPrimary, isQueued, depleted, specCost);
        }
    }

    private static string Label(string? weaponId) =>
        weaponId is null ? "" : weaponId.Replace("wpn_", "").Replace("_", " ").ToUpperInvariant();

    private string CurrentStyleLabel => State?.Player?.ChosenStyle switch
    {
        AttackStyle.Aggressive => "AGG",
        AttackStyle.Defensive  => "DEF",
        _                      => "ACC",
    };

    private Task CycleStyle()
    {
        var next = State?.Player?.ChosenStyle switch
        {
            AttackStyle.Accurate   => AttackStyle.Aggressive,
            AttackStyle.Aggressive => AttackStyle.Defensive,
            _                      => AttackStyle.Accurate,
        };
        return Run(() => GameSvc.DispatchAsync(new SetStyleCommand(GameSvc.PlayerId!, next)));
    }

    private async Task Run(Func<Task> action)
    {
        if (_busy || GameSvc.PlayerId is null) return;
        _busy = true;
        StateHasChanged();
        try { await action(); }
        finally { _busy = false; }
    }

    private Task Attack()                  => Run(() => GameSvc.DispatchAsync(new AttackCommand(GameSvc.PlayerId!, AttackStyle.Accurate)));
    private Task Spec()                    => Run(() => GameSvc.DispatchAsync(new AttackCommand(GameSvc.PlayerId!, AttackStyle.Accurate, UseSpecial: true)));
    private Task WeaponShortcut(string id) => Run(() => GameSvc.DispatchAsync(new WeaponShortcutCommand(GameSvc.PlayerId!, id)));
    private Task Boost()                   => Run(() => GameSvc.DispatchAsync(new PrayerCommand(GameSvc.PlayerId!, "boost")));
    private Task Sip(int slot)             => Run(() => GameSvc.DispatchAsync(new SipFlaskCommand(GameSvc.PlayerId!, slot)));

    private sealed record WeaponSlotDef(string? WeaponId, string Label, bool IsPrimary, bool IsQueued, bool SpecDepleted, int? SpecCost);
}
