@using Duels.Application.GameSession
@using Duels.Domain.ValueObjects

<div class="stats-panel">
    <div class="panel-title">Character</div>
    @if (State?.Player is { } p)
    {
        <div class="stat-name">@p.Name</div>
        <div class="stat-row">
            <span class="stat-label">HP</span>
            <div class="hp-bar-wrap">
                <div class="hp-bar" style="width: @(HpPercent(p))%"></div>
            </div>
            <span class="stat-val">@p.CurrentHp / @p.MaxHp</span>
        </div>
        <div class="stat-row"><span class="stat-label">Style</span><span class="stat-val stat-style">@StyleLabel(p.ChosenStyle)</span></div>
        <div class="stat-row"><span class="stat-label">Gold</span><span class="stat-val">@p.Gold gp</span></div>
        <div class="stat-row">
            <span class="stat-label">Special</span>
            <div class="spec-bar-wrap">
                <div class="spec-bar" style="width: @p.SpecialEnergy%"></div>
            </div>
            <span class="stat-val">@p.SpecialEnergy%</span>
        </div>
        <div class="stat-row">
            <span class="stat-label">Prayer</span>
            <div class="spec-bar-wrap">
                <div class="prayer-bar" style="width: @p.PrayerPoints%"></div>
            </div>
            <span class="stat-val">@p.PrayerPoints</span>
        </div>
        @if (p.ActiveProtection != ProtectionPrayer.None)
        {
            <div class="stat-row"><span class="stat-label">Protect</span><span class="stat-val stat-prayer">⛉ @p.ActiveProtection</span></div>
        }
        @if (p.BoostPrayerActive)
        {
            <div class="stat-row"><span class="stat-label">Boost</span><span class="stat-val stat-piety">⚡ ON</span></div>
        }
        @if (p.PersonalBestKillTicks is { } best)
        {
            <div class="stat-row"><span class="stat-label">Best kill</span><span class="stat-val">@((best * 0.6).ToString("F1"))s</span></div>
        }
        @if (State.BleedTicksLeft > 0)
        {
            <div class="stat-row"><span class="stat-label">Bleed</span><span class="stat-val status-chip status-chip-bleed">@State.BleedTicksLeft ticks</span></div>
        }
        @if (State.PlayerPoisoned)
        {
            <div class="stat-row"><span class="stat-label">Poison</span><span class="stat-val status-chip status-chip-poison">ACTIVE</span></div>
        }
    }
    else
    {
        <div class="stat-empty">No character</div>
    }
</div>

@code {
    [Parameter] public GameState? State { get; set; }

    private static int HpPercent(Duels.Domain.Entities.Player p) =>
        p.MaxHp == 0 ? 0 : (int)(p.CurrentHp * 100.0 / p.MaxHp);

    private static string StyleLabel(AttackStyle style) => style switch
    {
        AttackStyle.Aggressive => "AGGRESSIVE",
        AttackStyle.Defensive  => "DEFENSIVE",
        _                      => "ACCURATE",
    };
}
