@using Duels.Application.GameSession

<div class="hub-menu">
    <button class="hub-card hub-card-fight" disabled="@(Processing || !HasLoadout)" @onclick="() => OnFight.InvokeAsync()">
        <span class="hub-card-icon">🐛</span>
        <span class="hub-card-body">
            <span class="hub-card-title">FIGHT THE MAGGOT KING</span>
            <span class="hub-card-sub">@(HasLoadout ? "9×9 arena — prayer flicks and ground hazards" : "Grab a dev loadout first")</span>
        </span>
    </button>

    @if (State?.LastOpponentId is not null)
    {
        <button class="hub-card hub-card-retry" disabled="@Processing" @onclick="() => OnRetry.InvokeAsync()">
            <span class="hub-card-icon">⚔</span>
            <span class="hub-card-body">
                <span class="hub-card-title">RETRY</span>
                <span class="hub-card-sub">Rematch your last opponent</span>
            </span>
        </button>
    }

    <button class="hub-card hub-card-loadout" disabled="@Processing" @onclick="() => OnOpenLoadout.InvokeAsync()">
        <span class="hub-card-icon">🗡</span>
        <span class="hub-card-body">
            <span class="hub-card-title">LOADOUT EDITOR</span>
            <span class="hub-card-sub">Bind your action bar and flask belt</span>
        </span>
    </button>

    <button class="hub-card hub-card-bank" disabled="@Processing" @onclick="() => OnOpenBank.InvokeAsync()">
        <span class="hub-card-icon">🏦</span>
        <span class="hub-card-body">
            <span class="hub-card-title">BANK</span>
            <span class="hub-card-sub">Deposit loot, free up bag space</span>
        </span>
    </button>

    <button class="hub-card hub-card-shop" disabled="@Processing" @onclick="() => OnOpenShop.InvokeAsync()">
        <span class="hub-card-icon">💰</span>
        <span class="hub-card-body">
            <span class="hub-card-title">GOLD SHOP</span>
            <span class="hub-card-sub">Buy weapons, armour, flasks</span>
        </span>
    </button>

    @* PROVISIONAL: these dev-loadout grants have no dev gate (backlog.md #25)
       -- always visible to any player, not just a debug build. Now that the
       cold-start FTUE grants real starting gear (batch 4), these are pure
       testing shortcuts, not the only way to get geared. *@
    <div class="hub-card-group">
        <button class="hub-card hub-card-test" disabled="@Processing" @onclick="() => OnGrantDevLoadout.InvokeAsync(1)">
            <span class="hub-card-icon">⚗</span>
            <span class="hub-card-body">
                <span class="hub-card-title">DEV: T1 LOADOUT</span>
                <span class="hub-card-sub">Rustcleaver/Poacher's Bow/Cinder Wand + Warbound armour</span>
            </span>
        </button>

        <button class="hub-card hub-card-test" disabled="@Processing" @onclick="() => OnGrantDevLoadout.InvokeAsync(2)">
            <span class="hub-card-icon">⚗</span>
            <span class="hub-card-body">
                <span class="hub-card-title">DEV: T2 LOADOUT</span>
                <span class="hub-card-sub">Splitter/Bolt Thrower/Hexknot Staff + Warbound armour</span>
            </span>
        </button>
    </div>

    @* Relative href (not a leading-slash absolute URL) so Blazor's router
       intercepts the click for client-side navigation regardless of
       whether the app is mounted at /duels/ or /duels/dev/ — a direct
       browser navigation to this URL instead hits GitHub Pages' single
       site-wide 404.html, which loads the wrong build. *@
    <a class="hub-card hub-card-anim-editor" href="anim-editor">
        <span class="hub-card-icon">🎬</span>
        <span class="hub-card-body">
            <span class="hub-card-title">ANIM EDITOR</span>
            <span class="hub-card-sub">Keyframe weapon poses — dev tool</span>
        </span>
    </a>
</div>

@code {
    [Parameter] public GameState? State { get; set; }
    [Parameter] public bool Processing { get; set; }
    [Parameter] public EventCallback OnFight { get; set; }
    [Parameter] public EventCallback OnRetry { get; set; }
    [Parameter] public EventCallback OnOpenLoadout { get; set; }
    [Parameter] public EventCallback OnOpenBank { get; set; }
    [Parameter] public EventCallback OnOpenShop { get; set; }
    [Parameter] public EventCallback<int> OnGrantDevLoadout { get; set; }

    private bool HasLoadout => State?.Player?.Loadout.WeaponSlots.Any(w => w is not null) == true;
}
