@using Duels.Application.GameSession
@using Duels.Application.Abstractions
@using Duels.Domain.Entities
@inject IItemRepository ItemRepo
@inject INpcRepository NpcRepo

<div class="shop-overlay" @onclick="OnClose">
    <div class="shop-panel log-panel" @onclick:stopPropagation>
        <div class="shop-header">
            <span class="shop-title">Collection Log</span>
            <span class="shop-gold">@ObtainedCount / @TotalSignatureCount drops</span>
            <button class="shop-close" @onclick="OnClose" title="Close">✕</button>
        </div>

        <div class="log-section">
            <div class="panel-title">Achievements</div>
            <div class="log-achievements">
                @foreach (var a in Achievements())
                {
                    <div class="log-achievement @(a.Unlocked ? "log-achievement-done" : "")">
                        <span class="log-ach-icon">@(a.Unlocked ? "✓" : "🔒")</span>
                        <span class="log-ach-name">@a.Name</span>
                    </div>
                }
            </div>
        </div>

        <div class="log-section log-drops">
            <div class="panel-title">NPC Drops</div>
            @foreach (var npcId in _order)
            {
                var template = NpcRepo.GetTemplate(npcId);
                if (template is null || template.LootTable.Count == 0) continue;
                bool defeated = State?.DefeatedNpcs.Contains(npcId) ?? false;
                <div class="log-npc-row">
                    <div class="log-npc-name">@(defeated ? "" : "??? ")@(defeated ? template.Name : "Undiscovered")</div>
                    <div class="log-drop-list">
                        @foreach (var entry in template.LootTable.Where(e => e.ItemId != "gold"))
                        {
                            bool obtained = State?.CollectionLog.Contains(entry.ItemId) ?? false;
                            var name = obtained ? (ItemRepo.GetItemName(entry.ItemId) ?? entry.ItemId) : "???";
                            <span class="log-drop-chip @(obtained ? "log-drop-obtained" : "")" title="@(obtained ? name : "Not yet obtained")">
                                @(obtained ? "✓" : "?") @name
                            </span>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public GameState? State { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private static readonly string[] _order =
    [
        "goblin", "swashbuckler", "barbarian", "desert_bandit", "gladiator",
        "corsair", "berserker", "warlord", "champion", "rare_gladiator", "rare_tourist",
    ];

    private int TotalSignatureCount =>
        _order.Select(id => NpcRepo.GetTemplate(id))
              .Where(t => t is not null)
              .SelectMany(t => t!.LootTable)
              .Count(e => e.ItemId != "gold");

    private int ObtainedCount => State?.CollectionLog.Count ?? 0;

    private sealed record Achievement(string Name, bool Unlocked);

    private IEnumerable<Achievement> Achievements()
    {
        var s = State;
        yield return new("First Blood — win a duel", (s?.DefeatedNpcs.Count ?? 0) > 0);
        yield return new("Ladder Cleared — beat every ladder NPC", _order.Take(9).All(id => s?.DefeatedNpcs.Contains(id) ?? false));
        yield return new("Prayer Dancer — defeat the Champion", s?.DefeatedNpcs.Contains("champion") ?? false);
        yield return new("Ascended — reach Prestige 1", (s?.Player?.PrestigeLevel ?? 0) >= 1);
        yield return new("Endless Wanderer — reach wave 10", (s?.BestEndlessWave ?? 0) >= 10);
        yield return new("Endless Legend — reach wave 25", (s?.BestEndlessWave ?? 0) >= 25);
        yield return new("Collector — obtain 5 signature drops", (s?.CollectionLog.Count ?? 0) >= 5);
        yield return new("Hoarder — obtain every signature drop", TotalSignatureCount > 0 && ObtainedCount >= TotalSignatureCount);
    }
}
