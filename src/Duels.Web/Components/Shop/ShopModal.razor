@using Duels.Application.GameSession
@using Duels.Application.Commands
@inject Duels.Web.Services.GameService GameSvc

<div class="shop-overlay" @onclick="OnClose">
    <div class="shop-panel" @onclick:stopPropagation>
        <div class="shop-header">
            <span class="shop-title">Shop</span>
            <span class="shop-gold">@(State?.Player?.Gold.ToString("N0") ?? "0") gp</span>
            <button class="shop-close" @onclick="OnClose" title="Close">✕</button>
        </div>

        <div class="shop-tabs">
            <button class="shop-tab @(_tab == "weapons" ? "active" : "")" @onclick='() => SetTab("weapons")'>Weapons</button>
            <button class="shop-tab @(_tab == "armor"   ? "active" : "")" @onclick='() => SetTab("armor")'>Armor</button>
            <button class="shop-tab @(_tab == "food"    ? "active" : "")" @onclick='() => SetTab("food")'>Food</button>
            <button class="shop-tab @(_tab == "potions" ? "active" : "")" @onclick='() => SetTab("potions")'>Potions</button>
        </div>

        <div class="shop-qty-row">
            @foreach (var q in _quantities)
            {
                var qLocal = q;
                <button class="shop-qty @(_qty == qLocal ? "active" : "")"
                        @onclick="() => { _qty = qLocal; _confirmItemId = null; }">×@qLocal</button>
            }
        </div>

        <div class="shop-grid">
            @foreach (var item in CurrentItems())
            {
                var itemLocal = item;
                @if (_confirmItemId == item.Id)
                {
                    <div class="shop-confirm-cell">
                        <span class="shop-cell-name">@item.Name</span>
                        <span class="shop-cell-price">@((item.Price * _qty).ToString("N0"))g</span>
                        <button class="shop-confirm-btn" @onclick="() => ExecuteBuy(itemLocal)">Confirm</button>
                        <button class="shop-cancel-btn"  @onclick="() => _confirmItemId = null">Cancel</button>
                    </div>
                }
                else
                {
                    var reqUnmet = ReqUnmet(item);
                    var reqLabel = item.AtkReq > 0 ? $"{item.AtkReq} Atk" : item.DefReq > 0 ? $"{item.DefReq} Def" : null;
                    <button class="shop-cell @(reqUnmet ? "shop-cell-locked" : "")" @onclick="() => OnCellClick(itemLocal)"
                            title="@item.Name — @item.Price.ToString("N0")g@(reqLabel is not null ? $" (needs {reqLabel})" : "")">
                        <span class="shop-cell-icon">@item.Icon</span>
                        <span class="shop-cell-name">@item.Name</span>
                        <span class="shop-cell-price">@item.Price.ToString("N0")g</span>
                        @if (reqLabel is not null)
                        {
                            <span class="shop-cell-req @(reqUnmet ? "shop-req-unmet" : "")">@reqLabel</span>
                        }
                    </button>
                }
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public GameState? State { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private bool _busy;

    private string _tab = "weapons";
    private int _qty = 1;
    private string? _confirmItemId = null;
    private static readonly int[] _quantities = [1, 5, 10];

    private sealed record ShopItem(string Id, string Name, int Price, string Icon, bool NeedsConfirm = false, int AtkReq = 0, int DefReq = 0);

    private static readonly ShopItem[] _weapons =
    [
        new("rune_scimitar",      "Rune Scim",    200,    "⚔", AtkReq: 60),
        new("dragon_scimitar",    "D Scim",       600,    "⚔", AtkReq: 65),
        new("dragon_dagger",      "D Dagger",     800,    "⚔", AtkReq: 65),
        new("granite_maul",       "G Maul",       1_800,  "🔨", AtkReq: 65),
        new("abyssal_whip",       "Whip",         2_500,  "⚔", AtkReq: 70),
        new("zamorakian_hasta",   "Z Hasta",      3_500,  "🗡", AtkReq: 70),
        new("armadyl_sword",      "A Sword",      5_000,  "⚔", AtkReq: 72),
        new("dragon_claws",       "D Claws",      15_000, "⚔", AtkReq: 75),
        new("abyssal_bludgeon",   "Bludgeon",     28_000, "🔨", AtkReq: 78),
        new("bandos_godsword",    "BGS",          30_000, "⚔", AtkReq: 80),
        new("zamorak_godsword",   "ZGS",          40_000, "⚔", AtkReq: 80),
        new("ghrazi_rapier",      "Rapier",       45_000, "🗡", AtkReq: 80),
        new("saradomin_godsword", "SGS",          50_000, "⚔", AtkReq: 80),
        new("armadyl_godsword",   "AGS",          65_000, "⚔", NeedsConfirm: true, AtkReq: 82),
        new("elder_maul",         "E Maul",       90_000, "🔨", NeedsConfirm: true, AtkReq: 85),
        new("scythe_of_vitur",    "Scythe",      150_000, "⚔", NeedsConfirm: true, AtkReq: 90),
    ];

    private static readonly ShopItem[] _armor =
    [
        new("rune_full_helm",      "R Helm",      500,    "⛑", DefReq: 60),
        new("rune_kiteshield",     "R Shield",    800,    "🛡", DefReq: 60),
        new("rune_platelegs",      "R Legs",      1_200,  "👖", DefReq: 60),
        new("rune_platebody",     "R Body",      2_000,  "🎽", DefReq: 60),
        new("dragon_med_helm",     "D Helm",      3_000,  "⛑", DefReq: 70),
        new("dragon_boots",        "D Boots",     4_000,  "👢", DefReq: 65),
        new("dragon_sq_shield",   "D Shield",    4_000,  "🛡", DefReq: 70),
        new("dragon_platelegs",   "D Legs",      6_000,  "👖", DefReq: 70),
        new("barrows_gloves",     "Barrows Glvs", 6_000,  "🧤", DefReq: 70),
        new("dragon_platebody",   "D Body",      9_000,  "🎽", DefReq: 70),
        new("amulet_of_fury",     "Fury",       15_000,  "📿", DefReq: 70),
        new("justiciar_faceguard", "Justiciar",  30_000, "⛑", DefReq: 82, NeedsConfirm: true),
        new("dragonfire_shield",  "DFS",         35_000,  "🛡", DefReq: 82, NeedsConfirm: true),
        new("bandos_tassets",     "Bandos Legs", 45_000,  "👖", DefReq: 82, NeedsConfirm: true),
        new("bandos_chestplate", "Bandos Body", 60_000,  "🎽", DefReq: 82, NeedsConfirm: true),
    ];

    private static readonly ShopItem[] _food =
    [
        new("karambwan",  "Karambwan", 200, "🦑"),
        new("shark",      "Shark",     500, "🦈"),
        new("anglerfish", "Angler",    700, "🐟"),
    ];

    private static readonly ShopItem[] _potions =
    [
        new("super_combat_potion", "Super Cbt", 1_000, "⚗"),
        new("antidote",            "Antidote",    300, "🧪"),
    ];

    private ShopItem[] CurrentItems() => _tab switch
    {
        "armor"   => _armor,
        "food"    => _food,
        "potions" => _potions,
        _         => _weapons,
    };

    private void SetTab(string tab) { _tab = tab; _confirmItemId = null; }

    private bool ReqUnmet(ShopItem item) =>
        (item.AtkReq > 0 && (State?.Player?.AttackLevel ?? 0) < item.AtkReq) ||
        (item.DefReq > 0 && (State?.Player?.DefenceLevel ?? 0) < item.DefReq);

    private async Task OnCellClick(ShopItem item)
    {
        if (item.NeedsConfirm) { _confirmItemId = item.Id; return; }
        await ExecuteBuy(item);
    }

    private async Task ExecuteBuy(ShopItem item)
    {
        if (_busy || GameSvc.PlayerId is null) return;
        _confirmItemId = null;
        _busy = true;
        StateHasChanged();
        try { await GameSvc.DispatchAsync(new BuyItemCommand(GameSvc.PlayerId!, item.Id, _qty)); }
        finally { _busy = false; }
    }
}
