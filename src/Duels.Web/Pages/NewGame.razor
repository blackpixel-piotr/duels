@page "/"
@inject Duels.Web.Services.GameService Game
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="new-game-screen">
    <button class="fullscreen-btn" @onclick="ToggleFullscreen" title="Toggle fullscreen">⛶</button>
    <div class="new-game-box">
        <pre class="title-art glow-green">
  ____  _   _ _____ _     ____
 |  _ \| | | | ____| |   / ___|
 | | | | | | |  _| | |   \___ \
 | |_| | |_| | |___| |___ ___) |
 |____/ \___/|_____|_____|____/
        </pre>
        <p class="subtitle">A RuneScape-inspired duel game</p>

        @if (!string.IsNullOrEmpty(_error))
        {
            <p class="error-msg">@_error</p>
        }

        @if (_saveName is not null)
        {
            <div class="save-section">
                <p class="save-label">Saved character: <strong class="save-name">@_saveName</strong></p>
                <button class="continue-btn" @onclick="ContinueGame" disabled="@_starting">
                    @(_starting ? "Loading..." : "▶ Continue")
                </button>
                <button class="delete-save-btn" @onclick="DeleteSave">Delete save</button>
            </div>
            <div class="divider">— or start fresh —</div>
        }

        <div class="name-form">
            <label for="charname">Enter your character name:</label>
            <input id="charname"
                   type="text"
                   @bind="_playerName"
                   @onkeydown="OnKeyDown"
                   maxlength="20"
                   placeholder="e.g. Zezima"
                   autocomplete="off"
                   spellcheck="false" />

            @* Backlog resolution batch 1 §4: cold-start FTUE beat — choose a
               style, get its T1 weapon free (600g start covers the rest). *@
            <label class="style-pick-label">Choose your style — you'll start with its T1 weapon:</label>
            <div class="style-pick-row">
                <button class="style-pick-btn style-pick-melee @(_chosenStyle == "Melee" ? "active" : "")" @onclick='() => SelectStyle("Melee")'>
                    ⚔ Melee<span class="style-pick-sub">Rustcleaver</span>
                </button>
                <button class="style-pick-btn style-pick-ranged @(_chosenStyle == "Ranged" ? "active" : "")" @onclick='() => SelectStyle("Ranged")'>
                    ➶ Ranged<span class="style-pick-sub">Poacher's Bow</span>
                </button>
                <button class="style-pick-btn style-pick-magic @(_chosenStyle == "Magic" ? "active" : "")" @onclick='() => SelectStyle("Magic")'>
                    ✦ Magic<span class="style-pick-sub">Cinder Wand</span>
                </button>
            </div>

            <button class="continue-btn" @onclick="StartGame" disabled="@(_starting || _chosenStyle is null)">
                @(_starting ? "Creating..." : "▶ BEGIN ADVENTURE")
            </button>
        </div>

        <div class="hint-text">
            <p>Free T1 weapon + 600g · Face the Maggot King · Flick your prayers</p>
        </div>
    </div>
</div>

@code {
    private string _playerName = "";
    private string _error = "";
    private bool _starting;
    private string? _saveName;
    private string? _chosenStyle;

    protected override async Task OnInitializedAsync()
    {
        if (Game.IsStarted)
        {
            Nav.NavigateTo("game");
            return;
        }
        _saveName = await Game.GetSaveNameAsync();
    }

    private void SelectStyle(string style) => _chosenStyle = style;

    private async Task ToggleFullscreen() => await JS.InvokeVoidAsync("toggleFullscreen");

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await StartGame();
    }

    private async Task StartGame()
    {
        _error = "";
        var name = _playerName.Trim();
        if (name.Length < 1)
        {
            _error = "Please enter a name.";
            return;
        }
        if (name.Length > 20)
        {
            _error = "Name too long (max 20 characters).";
            return;
        }
        if (_chosenStyle is null)
        {
            _error = "Choose a style first.";
            return;
        }

        _starting = true;
        await Game.ClearSaveAsync();
        var result = await Game.StartNewGameAsync(name, _chosenStyle);
        _starting = false;

        if (result.Success)
            Nav.NavigateTo("game");
        else
            _error = string.Join(" ", result.Messages);
    }

    private async Task ContinueGame()
    {
        _starting = true;
        var ok = await Game.RestoreSaveAsync();
        _starting = false;

        if (ok)
            Nav.NavigateTo("game");
        else
            _error = "Failed to load save. Start a new game.";
    }

    private async Task DeleteSave()
    {
        await Game.ClearSaveAsync();
        _saveName = null;
    }
}
