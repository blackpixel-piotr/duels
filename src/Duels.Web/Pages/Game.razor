@page "/game"
@inject Duels.Web.Services.GameService GameSvc
@inject Duels.Application.Services.GameTickService TickService
@inject IJSRuntime JS
@inject NavigationManager Nav
@implements IDisposable

@using Duels.Application.GameSession
@using Duels.Application.Commands
@using Duels.Web.Components.Combat
@using Duels.Web.Components.Terminal
@using Duels.Web.Components.Hud
@using Duels.Web.Components.Hub
@using Duels.Web.Components.Bag
@using Duels.Web.Components.Shop
@using Duels.Web.Components.Ladder
@using Duels.Web.Components.Log

@if (!GameSvc.IsStarted)
{
    <p class="redirecting">Redirecting...</p>
}
else
{
    <div class="game-shell">
        @if (_shopOpen)
        {
            <ShopModal State="@_state"
                       OnClose="@(() => { _shopOpen = false; StateHasChanged(); })" />
        }
        @if (_ladderOpen)
        {
            <NpcLadderModal State="@_state"
                            OnClose="@(() => { _ladderOpen = false; StateHasChanged(); })"
                            OnDuelStarted="HandleDuelStarted" />
        }
        @if (_logOpen)
        {
            <CollectionLogModal State="@_state"
                                 OnClose="@(() => { _logOpen = false; StateHasChanged(); })" />
        }
        @if (_bagOpen)
        {
            <BagSheet State="@_state"
                      OnClose="@(() => { _bagOpen = false; StateHasChanged(); })" />
        }
        @if (_charOpen)
        {
            <CharacterSheet State="@_state"
                            OnClose="@(() => { _charOpen = false; StateHasChanged(); })" />
        }

        <ToastHost LogEntries="@(_state?.CombatLog.ToList() ?? [])" />
        <StatusStrip State="@_state" />

        @if (_state?.InDuel == true)
        {
            <CombatStage State="@_state" />
            <EventLog LogEntries="@(_state?.CombatLog.ToList() ?? [])" />
        }
        else
        {
            <HubMenu State="@_state"
                     Processing="@_processing"
                     RetryLabel="@RetryLabel"
                     OnArena="@(() => { _ladderOpen = true; StateHasChanged(); })"
                     OnEndless="StartEndless"
                     OnShop="@(() => { _shopOpen = true; StateHasChanged(); })"
                     OnRetry="RetryDuel"
                     OnPrestige="Prestige"
                     OnBeg="Beg" />
            <EventLog LogEntries="@(_state?.CombatLog.ToList() ?? [])" />
        }

        <ActionHud State="@_state"
                   OnOpenShop="@(() => { _shopOpen = true; StateHasChanged(); })"
                   OnOpenLadder="@(() => { _ladderOpen = true; StateHasChanged(); })"
                   OnOpenLog="@(() => { _logOpen = true; StateHasChanged(); })"
                   OnOpenBag="@(() => { _bagOpen = true; StateHasChanged(); })"
                   OnOpenCharacter="@(() => { _charOpen = true; StateHasChanged(); })" />
    </div>
}

@code {
    private GameState? _state;
    private bool _shopOpen   = false;
    private bool _ladderOpen = false;
    private bool _logOpen    = false;
    private bool _bagOpen    = false;
    private bool _charOpen   = false;
    private bool _processing = false;
    private bool _wasDueling = false;

    protected override async Task OnInitializedAsync()
    {
        if (!GameSvc.IsStarted)
        {
            Nav.NavigateTo("");
            return;
        }
        TickService.RegisterNotify(OnTickNotify);
        GameSvc.StateChanged += OnStateChanged;
        _state = await GameSvc.GetStateAsync();
        _wasDueling = _state?.InDuel ?? false;
    }

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    private void OnTickNotify()
    {
        _ = InvokeAsync(async () =>
        {
            bool isDueling = _state?.InDuel ?? false;
            if (_wasDueling && !isDueling)
            {
                TickService.Stop();
                await JS.InvokeVoidAsync("stopMetronome");
            }
            _wasDueling = isDueling;
            StateHasChanged();
        });
    }

    private async Task HandleDuelStarted()
    {
        _ladderOpen = false;
        await SyncTickService(_wasDueling);
        StateHasChanged();
    }

    private async Task RetryDuel()
    {
        if (_processing || GameSvc.PlayerId is null || _state?.LastOpponentId is null) return;
        await RunDuelAction(() =>
            GameSvc.DispatchAsync(new StartDuelCommand(GameSvc.PlayerId!, _state!.LastOpponentId!, RetryWager)));
    }

    private async Task StartEndless()
    {
        if (_processing || GameSvc.PlayerId is null) return;
        await RunDuelAction(() =>
            GameSvc.DispatchAsync(new StartEndlessCommand(GameSvc.PlayerId!)));
    }

    private async Task Prestige()
    {
        if (_processing || GameSvc.PlayerId is null) return;
        _processing = true;
        StateHasChanged();
        try { await GameSvc.DispatchAsync(new PrestigeCommand(GameSvc.PlayerId!)); }
        finally { _processing = false; StateHasChanged(); }
    }

    private async Task Beg()
    {
        if (_processing || GameSvc.PlayerId is null) return;
        _processing = true;
        StateHasChanged();
        try { await GameSvc.DispatchAsync(new BegCommand(GameSvc.PlayerId!)); }
        finally { _processing = false; StateHasChanged(); }
    }

    private async Task RunDuelAction(Func<Task> dispatch)
    {
        _processing = true;
        StateHasChanged();
        bool wasDueling = _state?.InDuel ?? false;
        try
        {
            await dispatch();
            await SyncTickService(wasDueling);
        }
        finally
        {
            _processing = false;
            StateHasChanged();
        }
    }

    private async Task SyncTickService(bool wasDueling)
    {
        bool isDueling = _state?.InDuel ?? false;
        if (!wasDueling && isDueling)
        {
            _wasDueling = true;
            TickService.Start(GameSvc.PlayerId!);
            await JS.InvokeVoidAsync("startMetronome");
        }
        else if (wasDueling && !isDueling)
        {
            _wasDueling = false;
            TickService.Stop();
            await JS.InvokeVoidAsync("stopMetronome");
        }
    }

    private int RetryWager =>
        (_state?.LastWager ?? 0) > 0 && (_state?.Player?.Gold ?? 0) >= _state!.LastWager
            ? _state!.LastWager : 0;

    private string RetryLabel =>
        RetryWager > 0 ? $"RETRY ({RetryWager:N0}g)" : "RETRY";

    public void Dispose()
    {
        GameSvc.StateChanged -= OnStateChanged;
        TickService.Stop();
    }
}
