@page "/game"
@inject Duels.Web.Services.GameService GameSvc
@inject Duels.Application.Services.GameTickService TickService
@inject IJSRuntime JS
@inject NavigationManager Nav
@implements IDisposable

@using Duels.Application.GameSession
@using Duels.Application.Commands
@using Duels.Web.Components.Combat
@using Duels.Web.Components.Hud
@using Duels.Web.Components.Hub
@using Duels.Web.Components.Bag
@using Duels.Web.Components.Loadout
@using Duels.Web.Components.Bank
@using Duels.Web.Components.Shop

@if (!GameSvc.IsStarted)
{
    <p class="redirecting">Redirecting...</p>
}
else
{
    <div class="game-shell">
        @if (_state?.InDuel == true || _duelResult is not null)
        {
            @* Full-bleed landscape fight: canvas fills the screen, HUD floats. *@
            <div class="battle-fs">
                @* Inside .battle-fs so toasts inherit the fight's auto-rotation. *@
                <ToastHost LogEntries="@(_state?.CombatLog.ToList() ?? [])" />
                <BattleScene State="@_state"
                             LogEntries="@(_state?.CombatLog.ToList() ?? [])"
                             EnemyDead="@(_duelResult?.Won == true)"
                             PlayerDead="@(_duelResult is { Won: false })"
                             WeaponId="@(_state?.Player?.GetEquippedWeaponId())" />
                <ActionHud State="@_state" Layout="float" />
                @if (_state?.InDuel == true)
                {
                    <PrayerStrip State="@_state" />
                }
                @if (_duelResult is not null)
                {
                    <DuelResultOverlay Summary="@_duelResult"
                                       ShowRetry="@CanRetry"
                                       RetryLabel="RETRY"
                                       OnContinue="@(() => { _duelResult = null; StateHasChanged(); })"
                                       OnRetry="RetryDuel" />
                }
            </div>
        }
        else
        {
            @* Landscape-everywhere mandate: the hub and its modal sheets
               auto-rotate to fill the screen in landscape when the device is
               held portrait, the same CSS trick .battle-fs uses for combat --
               no blocking "rotate your device" prompt, ever. *@
            <div class="hub-shell">
                @if (_bagOpen)
                {
                    <BagSheet State="@_state"
                              OnClose="@(() => { _bagOpen = false; StateHasChanged(); })" />
                }
                @if (_charOpen)
                {
                    <CharacterSheet State="@_state"
                                    OnClose="@(() => { _charOpen = false; StateHasChanged(); })" />
                }
                @if (_loadoutOpen)
                {
                    <LoadoutEditor State="@_state"
                                   OnClose="@(() => { _loadoutOpen = false; StateHasChanged(); })" />
                }
                @if (_bankOpen)
                {
                    <BankSheet State="@_state"
                               OnClose="@(() => { _bankOpen = false; StateHasChanged(); })" />
                }
                @if (_shopOpen)
                {
                    <ShopSheet State="@_state"
                               OnClose="@(() => { _shopOpen = false; StateHasChanged(); })" />
                }

                <ToastHost LogEntries="@(_state?.CombatLog.ToList() ?? [])" />
                <StatusStrip State="@_state" />
                <HubMenu State="@_state"
                         Processing="@_processing"
                         OnFight="StartMaggotKingFight"
                         OnRetry="RetryDuel"
                         OnOpenLoadout="@(() => { _loadoutOpen = true; StateHasChanged(); })"
                         OnOpenBank="@(() => { _bankOpen = true; StateHasChanged(); })"
                         OnOpenShop="@(() => { _shopOpen = true; StateHasChanged(); })"
                         OnGrantDevLoadout="GrantDevLoadout" />

                <ActionHud State="@_state" Layout="dock"
                           OnOpenBag="@(() => { _bagOpen = true; StateHasChanged(); })"
                           OnOpenCharacter="@(() => { _charOpen = true; StateHasChanged(); })" />
            </div>
        }
    </div>
}

@code {
    private GameState? _state;
    private bool _bagOpen     = false;
    private bool _charOpen    = false;
    private bool _loadoutOpen = false;
    private bool _bankOpen    = false;
    private bool _shopOpen    = false;
    private bool _processing  = false;
    private bool _wasDueling  = false;
    private DuelSummary? _duelResult;

    protected override async Task OnInitializedAsync()
    {
        if (!GameSvc.IsStarted)
        {
            Nav.NavigateTo("");
            return;
        }
        TickService.RegisterNotify(OnTickNotify);
        GameSvc.StateChanged += OnStateChanged;
        _state = await GameSvc.GetStateAsync();
        _wasDueling = _state?.InDuel ?? false;
    }

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    // Persistence cadence (M0): GameService.DispatchAsync skips high-frequency
    // in-duel commands, so the duel's outcome is only ever guaranteed to disk
    // from here — once when the duel ends, and every PersistEveryNTicks as a
    // safety net against a hard crash mid-fight.
    private const int PersistEveryNTicks = 10; // ~6s at the 0.6s tick
    private int _ticksSinceLastPersist = 0;

    private void OnTickNotify()
    {
        _ = InvokeAsync(async () =>
        {
            bool isDueling = _state?.InDuel ?? false;
            if (_wasDueling && !isDueling)
            {
                TickService.Stop();
                await JS.InvokeVoidAsync("stopMetronome");
                _duelResult = _state?.LastDuelSummary;
                _ticksSinceLastPersist = 0;
                await GameSvc.PersistNowAsync();
            }
            else if (isDueling && ++_ticksSinceLastPersist >= PersistEveryNTicks)
            {
                _ticksSinceLastPersist = 0;
                await GameSvc.PersistNowAsync();
            }
            _wasDueling = isDueling;
            StateHasChanged();
        });
    }

    private async Task StartMaggotKingFight()
    {
        if (_processing || GameSvc.PlayerId is null) return;
        await RunDuelAction(() =>
            GameSvc.DispatchAsync(new StartDuelCommand(GameSvc.PlayerId!, "maggot_king")));
    }

    private async Task RetryDuel()
    {
        if (_processing || GameSvc.PlayerId is null || _state?.LastOpponentId is null) return;
        await RunDuelAction(() =>
            GameSvc.DispatchAsync(new StartDuelCommand(GameSvc.PlayerId!, _state!.LastOpponentId!)));
    }

    private async Task GrantDevLoadout(int tier)
    {
        if (_processing || GameSvc.PlayerId is null) return;
        _processing = true;
        StateHasChanged();
        try { await GameSvc.DispatchAsync(new GrantDevLoadoutCommand(GameSvc.PlayerId!, tier, "Warbound")); }
        finally { _processing = false; StateHasChanged(); }
    }

    private async Task RunDuelAction(Func<Task> dispatch)
    {
        _processing = true;
        StateHasChanged();
        bool wasDueling = _state?.InDuel ?? false;
        try
        {
            await dispatch();
            await SyncTickService(wasDueling);
        }
        finally
        {
            _processing = false;
            StateHasChanged();
        }
    }

    private async Task SyncTickService(bool wasDueling)
    {
        bool isDueling = _state?.InDuel ?? false;
        if (!wasDueling && isDueling)
        {
            _wasDueling = true;
            _duelResult = null; // new duel dismisses any lingering result screen
            TickService.Start(GameSvc.PlayerId!);
            await JS.InvokeVoidAsync("startMetronome");
        }
        else if (wasDueling && !isDueling)
        {
            _wasDueling = false;
            TickService.Stop();
            await JS.InvokeVoidAsync("stopMetronome");
        }
    }

    private bool CanRetry => _state?.LastOpponentId is not null;

    public void Dispose()
    {
        GameSvc.StateChanged -= OnStateChanged;
        TickService.Stop();
    }
}
