@page "/game"
@inject Duels.Web.Services.GameService GameSvc
@inject Duels.Application.Services.GameTickService TickService
@inject IJSRuntime JS
@inject NavigationManager Nav
@implements IDisposable

@using Duels.Application.GameSession
@using Duels.Web.Components.Combat
@using Duels.Web.Components.Stats
@using Duels.Web.Components.Terminal
@using Duels.Web.Components.QuickSlots
@using Duels.Web.Components.Inventory
@using Duels.Web.Components.Shop
@using Duels.Web.Components.Ladder

@if (!GameSvc.IsStarted)
{
    <p class="redirecting">Redirecting...</p>
}
else
{
    <div class="game-wrapper">
        <nav class="mobile-tabs">
            <button class="mobile-tab @(_tab == "combat"    ? "active" : "")" @onclick='() => _tab = "combat"'>Combat</button>
            <button class="mobile-tab @(_tab == "stats"     ? "active" : "")" @onclick='() => _tab = "stats"'>Stats</button>
            <button class="mobile-tab @(_tab == "inventory" ? "active" : "")" @onclick='() => _tab = "inventory"'>Items</button>
        </nav>

        @if (_shopOpen)
        {
            <ShopModal State="@_state"
                       OnClose="@(() => { _shopOpen = false; StateHasChanged(); })"
                       OnBuy="HandleBuy" />
        }

        @if (_ladderOpen)
        {
            <NpcLadderModal State="@_state"
                            OnClose="@(() => { _ladderOpen = false; StateHasChanged(); })"
                            OnDuel="HandleDuel" />
        }

        <div class="game-layout tab-@_tab">
            <div class="game-left">
                <StatsPanel State="@_state" />
            </div>

            <div class="game-center">
                <CombatStatusBar State="@_state" />
                <TerminalComponent LogEntries="@(_state?.CombatLog.ToList() ?? [])" />
                @if (_state is { InDuel: false, LastOpponentId: { } lastNpc })
                {
                    <div class="retry-bar">
                        <button class="retry-btn" disabled="@_processing" @onclick='() => HandleCommand(RetryCmd)'>@RetryLabel</button>
                    </div>
                }
                <div class="bottom-bar">
                    <QuickSlotBar State="@_state" OnCommand="HandleCommand" Disabled="@_processing" />
                    <TerminalInput OnSubmit="HandleCommand" Disabled="@_processing" />
                </div>
            </div>

            <div class="game-right">
                <InventoryGrid State="@_state" OnEquip="HandleCommand" />
            </div>
        </div>
    </div>
}

@code {
    private GameState? _state;
    private string _tab = "combat";
    private bool _shopOpen   = false;
    private bool _ladderOpen = false;
    private bool _processing = false;
    private bool _wasDueling = false;

    protected override async Task OnInitializedAsync()
    {
        if (!GameSvc.IsStarted)
        {
            Nav.NavigateTo("");
            return;
        }
        TickService.RegisterNotify(OnTickNotify);
        GameSvc.StateChanged += OnStateChanged;
        _state = await GameSvc.GetStateAsync();
        _wasDueling = _state?.InDuel ?? false;
    }

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    private void OnTickNotify()
    {
        _ = InvokeAsync(async () =>
        {
            bool isDueling = _state?.InDuel ?? false;
            if (_wasDueling && !isDueling)
            {
                TickService.Stop();
                await JS.InvokeVoidAsync("stopMetronome");
            }
            _wasDueling = isDueling;
            StateHasChanged();
        });
    }

    private async Task HandleCommand(string command)
    {
        if (string.IsNullOrWhiteSpace(command) || _processing) return;
        var verb = command.Trim().TrimStart('!').Split(' ', 2)[0].ToLowerInvariant();
        if (verb is "shop" or "store")               { _shopOpen   = true; StateHasChanged(); return; }
        if (verb is "npcs" or "enemies" or "list")   { _ladderOpen = true; StateHasChanged(); return; }
        _processing = true;
        StateHasChanged();
        bool wasDueling = _state?.InDuel ?? false;
        try
        {
            await GameSvc.ExecuteCommandAsync(command);
        }
        finally
        {
            _processing = false;
            _tab = "combat";
            await SyncTickService(wasDueling);
        }
    }

    private async Task SyncTickService(bool wasDueling)
    {
        bool isDueling = _state?.InDuel ?? false;
        if (!wasDueling && isDueling)
        {
            _wasDueling = true;
            TickService.Start(GameSvc.PlayerId!);
            await JS.InvokeVoidAsync("startMetronome");
        }
        else if (wasDueling && !isDueling)
        {
            _wasDueling = false;
            TickService.Stop();
            await JS.InvokeVoidAsync("stopMetronome");
        }
    }

    private async Task HandleBuy(string buyCmd)
    {
        await GameSvc.ExecuteCommandAsync(buyCmd);
        _state = await GameSvc.GetStateAsync();
        StateHasChanged();
    }

    private async Task HandleDuel(string duelCmd)
    {
        _ladderOpen = false;
        bool wasDueling = _state?.InDuel ?? false;
        await GameSvc.ExecuteCommandAsync(duelCmd);
        _tab = "combat";
        _state = await GameSvc.GetStateAsync();
        await SyncTickService(wasDueling);
        StateHasChanged();
    }

    private int RetryWager =>
        (_state?.LastWager ?? 0) > 0 && (_state?.Player?.Gold ?? 0) >= _state!.LastWager
            ? _state!.LastWager : 0;

    private string RetryCmd =>
        RetryWager > 0
            ? $"duel {_state?.LastOpponentId} {RetryWager}"
            : $"duel {_state?.LastOpponentId}";

    private string RetryLabel =>
        RetryWager > 0 ? $"⚔ Retry ({RetryWager:N0}g)" : "⚔ Retry";

    public void Dispose()
    {
        GameSvc.StateChanged -= OnStateChanged;
        TickService.Stop();
    }
}
